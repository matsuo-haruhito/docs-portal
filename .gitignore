# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# Bundler
/.bundle
/vendor/bundle/*
!/vendor/bundle/.keep

# Environment files
/.env
/.env.*
!/.env.example
*.local

# Rails logs, temp files, and pid files
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Uploaded files, generated sites, and local storage
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

# Rails credentials
/config/master.key

# Rails assets and Vite
/public/assets
/public/vite*
/node_modules/
/npm-debug.log*
/yarn-debug.log*
/yarn-error.log*
/pnpm-debug.log*

# Backups
/backup/*
!/backup/README.md

# Docusaurus dependencies and generated artifacts
/docusaurus/node_modules/
/docusaurus/.docusaurus/
/docusaurus/build/
/docusaurus/.cache/
/docusaurus/.turbo/
/docusaurus/static/generated/
/docusaurus/npm-debug.log*
/docusaurus/yarn-debug.log*
/docusaurus/yarn-error.log*
/docusaurus/pnpm-debug.log*

# Local Docker/build scratch files
/.docker-build-cache/
/tmp-docker-*/

# Codex / local AI assistant scratch files
/.codex/
.codex
.tmp.*
AGENTS.md
