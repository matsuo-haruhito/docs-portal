#!/usr/bin/env ruby
# frozen_string_literal: true

require "json"
require "optparse"
require_relative "../lib/local_folder_sync/upload_client"

options = {}

parser = OptionParser.new do |opts|
  opts.banner = "Usage: bin/local_folder_sync_upload [options]"

  opts.on("--portal-url=URL", "docs-portal base URL") { |value| options[:portal_url] = value }
  opts.on("--token=TOKEN", "internal import token; not printed") { |value| options[:token] = value }
  opts.on("--project-code=CODE", "target project code") { |value| options[:project_code] = value }
  opts.on("--sync-root=PATH", "local sync root") { |value| options[:sync_root] = value }
  opts.on("--source-name=NAME", "source name shown in dry-run preview") { |value| options[:source_name] = value }
  opts.on("--file=PATH", "file inside sync root to upload as dry-run") { |value| options[:file_path] = value }
  opts.on("--endpoint=PATH", "override upload endpoint path") { |value| options[:endpoint] = value }
end

parser.parse!(ARGV)

env_config = LocalFolderSync::UploadClient.config_from_env
config = LocalFolderSync::UploadClient::Config.new(
  portal_url: options.fetch(:portal_url, env_config.portal_url),
  token: options.fetch(:token, env_config.token),
  project_code: options.fetch(:project_code, env_config.project_code),
  sync_root: options.fetch(:sync_root, env_config.sync_root),
  source_name: options.fetch(:source_name, env_config.source_name),
  file_path: options.fetch(:file_path, env_config.file_path),
  endpoint: options.fetch(:endpoint, env_config.endpoint)
)

client = LocalFolderSync::UploadClient.new(config: config)
payload = client.call
puts JSON.pretty_generate(client.summary_for(payload))
exit 0
rescue LocalFolderSync::UploadClient::Error => e
  warn "local folder sync dry-run failed: #{e.message}"
  warn parser
  exit 1
