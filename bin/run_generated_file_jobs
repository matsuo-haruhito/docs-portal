#!/usr/bin/env ruby
# frozen_string_literal: true

require "open3"
require "pathname"
require "shellwords"

ROOT = Pathname(__dir__).join("..").expand_path
require_relative "../app/services/generated_files/runner"

class ChangedFilesDetector
  def call
    changed_files_from_env || changed_files_from_git
  end

  private

  def changed_files_from_env
    raw = ENV["GENERATED_FILE_JOB_CHANGED_FILES"]
    return if raw.nil? || raw.strip.empty?

    raw.split(/\r?\n|,/).map(&:strip).reject(&:empty?)
  end

  def changed_files_from_git
    base = ENV["GENERATED_FILE_JOB_BASE"]
    head = ENV.fetch("GENERATED_FILE_JOB_HEAD", "HEAD")
    command = if base && !base.empty?
      ["git", "diff", "--name-only", base, head]
    else
      ["git", "diff", "--name-only", "HEAD~1", head]
    end

    stdout, stderr, status = Open3.capture3(*command, chdir: ROOT.to_s)
    unless status.success?
      warn stderr unless stderr.empty?
      raise "failed to detect changed files: #{command.shelljoin}"
    end

    stdout.lines.map(&:strip).reject(&:empty?)
  end
end

registry = ENV.fetch("GENERATED_FILE_JOB_REGISTRY", GeneratedFiles::Runner::DEFAULT_REGISTRY_PATH)
explicit_files = ARGV.empty? ? nil : ARGV
changed_files = explicit_files || ChangedFilesDetector.new.call

GeneratedFiles::Runner.new(registry_path: registry, changed_files:, root: ROOT).call
