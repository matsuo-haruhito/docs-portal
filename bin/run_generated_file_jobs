#!/usr/bin/env ruby
# frozen_string_literal: true

require "open3"
require "pathname"
require "set"
require "shellwords"
require "yaml"

ROOT = Pathname(__dir__).join("..").expand_path
DEFAULT_REGISTRY = ROOT.join(".github/generated-file-jobs.yml")

class GeneratedFileJobRunner
  def initialize(registry_path:, changed_files: nil)
    @registry_path = Pathname(registry_path)
    @changed_files = normalize_files(changed_files || changed_files_from_env || changed_files_from_git)
  end

  def call
    jobs = YAML.safe_load(@registry_path.read, permitted_classes: [], aliases: false).fetch("jobs")
    selected_jobs = jobs.select { should_run?(_1) }

    if selected_jobs.empty?
      puts "No generated-file jobs matched changed files."
      puts "Changed files: #{changed_files.to_a.sort.join(', ')}" unless changed_files.empty?
      return
    end

    selected_jobs.each { run_job(_1) }
  end

  private

  attr_reader :changed_files

  def should_run?(job)
    watch_paths = Array(job.fetch("source_paths")) + Array(job.fetch("watch_paths", []))
    normalize_files(watch_paths).any? { |path| changed_files.include?(path) }
  end

  def run_job(job)
    id = job.fetch("id")
    command = job.fetch("command")
    puts "Running generated-file job: #{id}"
    puts "Command: #{command}"

    stdout, stderr, status = Open3.capture3(command, chdir: ROOT.to_s)
    puts stdout unless stdout.empty?
    warn stderr unless stderr.empty?
    raise "generated-file job failed: #{id}" unless status.success?

    generated_paths = Array(job.fetch("generated_paths", []))
    if generated_paths.empty?
      puts "No generated_paths declared for #{id}."
    else
      puts "Generated paths:"
      generated_paths.each { puts "- #{_1}" }
    end
  end

  def changed_files_from_env
    raw = ENV["GENERATED_FILE_JOB_CHANGED_FILES"]
    return if raw.nil? || raw.strip.empty?

    raw.split(/\r?\n|,/).map(&:strip).reject(&:empty?)
  end

  def changed_files_from_git
    base = ENV["GENERATED_FILE_JOB_BASE"]
    head = ENV.fetch("GENERATED_FILE_JOB_HEAD", "HEAD")
    command = if base && !base.empty?
      ["git", "diff", "--name-only", base, head]
    else
      ["git", "diff", "--name-only", "HEAD~1", head]
    end

    stdout, stderr, status = Open3.capture3(*command, chdir: ROOT.to_s)
    unless status.success?
      warn stderr unless stderr.empty?
      raise "failed to detect changed files: #{command.shelljoin}"
    end

    stdout.lines.map(&:strip).reject(&:empty?)
  end

  def normalize_files(files)
    files.each_with_object(Set.new) do |file, result|
      path = file.to_s.strip
      next if path.empty?

      result << Pathname(path).cleanpath.to_s.delete_prefix("./")
    end
  end
end

registry = Pathname(ENV.fetch("GENERATED_FILE_JOB_REGISTRY", DEFAULT_REGISTRY.to_s))
explicit_files = ARGV.empty? ? nil : ARGV
GeneratedFileJobRunner.new(registry_path: registry, changed_files: explicit_files).call
