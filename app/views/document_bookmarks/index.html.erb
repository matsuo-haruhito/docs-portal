<% page_title "文書ショートカット" %>
<% bookmark_project_filter_label = @selected_bookmark_project&.name || @bookmark_project_code %>
<% recent_clear_params = { project_code: @bookmark_project_code, bookmark_q: @bookmark_query.presence }.compact %>

<h1>文書ショートカット</h1>
<p class="muted">お気に入り、後で読む、最近見た文書を最低限の一覧で表示します。</p>

<section class="card">
  <h2>保存済みショートカットの絞り込み</h2>
  <p class="muted"><span class="badge">対象: お気に入り・後で読む</span> 最近見た文書は下の検索で絞り込みます。</p>
  <%= form_with url: document_bookmarks_path, method: :get, local: true do |form| %>
    <% if @recent_documents_query.present? %>
      <%= form.hidden_field :recent_q, value: @recent_documents_query %>
    <% end %>
    <div class="form-grid">
      <div class="field">
        <%= form.label :project_code, "案件" %>
        <%= form.select :project_code,
              options_for_select(@bookmark_project_options.map { |project| [project.name, project.code] }, @bookmark_project_code),
              { include_blank: "すべての案件" } %>
      </div>
      <div class="field">
        <%= form.label :bookmark_q, "保存済みショートカットを検索" %>
        <%= form.search_field :bookmark_q, value: @bookmark_query, maxlength: DocumentBookmarksController::BOOKMARK_QUERY_MAX_LENGTH, placeholder: "文書名・案件名・案件コード", autocomplete: "off" %>
      </div>
      <div class="form-actions">
        <%= form.submit "絞り込む", class: "button" %>
        <% if @saved_bookmark_filter_active %>
          <%= link_to "保存済み条件を解除", document_bookmarks_path(recent_q: @recent_documents_query.presence), class: "button secondary" %>
        <% end %>
      </div>
    </div>
  <% end %>
  <% if @saved_bookmark_filter_active %>
    <% if @bookmark_project_filter_active && @selected_bookmark_project && @bookmark_search_active %>
      <p class="muted">案件「<%= @selected_bookmark_project.name %>」と検索語「<%= @bookmark_query %>」でお気に入りと後で読むを絞り込んでいます。最近見た文書は絞り込み対象外です。</p>
    <% elsif @bookmark_project_filter_active && @selected_bookmark_project %>
      <p class="muted">案件「<%= @selected_bookmark_project.name %>」でお気に入りと後で読むを絞り込んでいます。最近見た文書は絞り込み対象外です。</p>
    <% elsif @bookmark_project_filter_active %>
      <p class="muted">指定した案件では保存済みショートカットが見つかりません。最近見た文書は絞り込み対象外です。</p>
    <% elsif @bookmark_search_active %>
      <p class="muted">検索語「<%= @bookmark_query %>」でお気に入りと後で読むを絞り込んでいます。最近見た文書は絞り込み対象外です。</p>
    <% end %>
  <% else %>
    <p class="muted">明示的に保存したお気に入りと後で読むだけを、案件や文書名・案件名で絞り込めます。</p>
  <% end %>
</section>

<section class="card">
  <h2>お気に入り <span class="muted"><%= @favorite_bookmarks.size %>件</span></h2>
  <p class="muted">よく開く文書をここからすぐ確認できます。後で読むにも同じ文書を残して、一時保留と継続参照を分けられます。</p>
  <% if @favorite_bookmarks.any? %>
    <ul class="resource-list">
      <% @favorite_bookmarks.each do |bookmark| %>
        <li class="resource-list__item">
          <div class="resource-list__content">
            <strong><%= link_to bookmark.document.title, project_document_path(bookmark.document.project, bookmark.document.slug) %></strong>
            <div class="resource-list__meta">
              <span class="muted"><%= bookmark.document.project.name %></span>
              <span class="badge">よく開く文書</span>
            </div>
          </div>
          <div class="resource-list__actions">
            <%= button_to "解除", document_bookmark_path(bookmark), method: :delete, class: "button secondary" %>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <% if @bookmark_search_active %>
      <p class="muted">保存済みショートカット検索「<%= @bookmark_query %>」に一致するお気に入りはありません。</p>
    <% elsif @bookmark_project_filter_active %>
      <p class="muted">案件「<%= bookmark_project_filter_label %>」ではお気に入りが見つかりません。</p>
    <% else %>
      <p class="muted">文書画面でお気に入りに追加すると、ここに表示されます。</p>
    <% end %>
  <% end %>
</section>

<section class="card">
  <h2>後で読む <span class="muted"><%= @read_later_bookmarks.size %>件</span></h2>
  <p class="muted">あとで確認したい文書を一時的に集めておけます。お気に入りに移動すると、この一覧からは外れます。</p>
  <% if @read_later_bookmarks.any? %>
    <ul class="resource-list">
      <% @read_later_bookmarks.each do |bookmark| %>
        <% also_favorite = @favorite_bookmark_document_ids.include?(bookmark.document_id) %>
        <li class="resource-list__item">
          <div class="resource-list__content">
            <strong><%= link_to bookmark.document.title, project_document_path(bookmark.document.project, bookmark.document.slug) %></strong>
            <div class="resource-list__meta">
              <span class="muted"><%= bookmark.document.project.name %></span>
              <span class="badge">あとで確認</span>
              <% if also_favorite %>
                <span class="badge">お気に入りにも保存中</span>
                <span class="muted">継続参照はお気に入りに残し、後で読むだけ整理できます。</span>
              <% end %>
            </div>
          </div>
          <div class="resource-list__actions">
            <% if also_favorite %>
              <p class="muted">移すと後で読むから外れ、お気に入りだけに残ります。</p>
            <% end %>
            <%= button_to "お気に入りへ移す", move_to_favorite_document_bookmark_path(bookmark), method: :post, class: "button" %>
            <%= button_to "解除", document_bookmark_path(bookmark), method: :delete, class: "button secondary" %>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <% if @bookmark_search_active %>
      <p class="muted">保存済みショートカット検索「<%= @bookmark_query %>」に一致する後で読む文書はありません。</p>
    <% elsif @bookmark_project_filter_active %>
      <p class="muted">案件「<%= bookmark_project_filter_label %>」では後で読む文書が見つかりません。</p>
    <% else %>
      <p class="muted">文書画面で後で読むに追加すると、ここに表示されます。</p>
    <% end %>
  <% end %>
</section>

<section class="card">
  <h2>最近見た文書 <span class="muted"><%= @recent_documents.size %>件</span></h2>
  <p class="muted"><span class="badge">対象: 最近見た文書（表示中最大 20 件）</span> 保存済みショートカットの条件はそのまま維持されます。</p>
  <p class="muted">閲覧履歴から最大 20 件を自動で表示します。この検索は表示中の最近見た文書だけを文書名・案件名で絞り込みます。お気に入りや後で読むとは別の一覧です。</p>

  <%= form_with url: document_bookmarks_path, method: :get, local: true, class: "filter-form" do |form| %>
    <% if @bookmark_project_code.present? %>
      <%= form.hidden_field :project_code, value: @bookmark_project_code %>
    <% end %>
    <% if @bookmark_query.present? %>
      <%= form.hidden_field :bookmark_q, value: @bookmark_query %>
    <% end %>
    <div class="form-field">
      <%= form.label :recent_q, "最近見た文書を検索" %>
      <%= form.search_field :recent_q, value: @recent_documents_query, maxlength: DocumentBookmarksController::BOOKMARK_QUERY_MAX_LENGTH, placeholder: "文書名・案件名で検索", autocomplete: "off" %>
    </div>
    <div class="form-actions">
      <%= form.submit "絞り込む", class: "button" %>
      <% if @recent_documents_query.present? %>
        <%= link_to "最近見た条件をクリア", document_bookmarks_path(recent_clear_params), class: "button secondary" %>
      <% end %>
    </div>
  <% end %>

  <% if @recent_documents_query.present? %>
    <p class="muted">最近見た文書検索「<%= @recent_documents_query %>」は、表示中の最大 20 件だけを絞り込んでいます。保存済みショートカットの条件は維持されます。</p>
  <% end %>

  <% if @recent_documents.any? %>
    <ul class="resource-list">
      <% @recent_documents.each do |document| %>
        <li class="resource-list__item">
          <div class="resource-list__content">
            <strong><%= link_to document.title, project_document_path(document.project, document.slug) %></strong>
            <div class="resource-list__meta">
              <span class="muted"><%= document.project.name %></span>
              <span class="badge">最近見た文書</span>
            </div>
          </div>
        </li>
      <% end %>
    </ul>
  <% elsif @all_recent_documents.any? %>
    <% if @recent_documents_query.present? %>
      <p class="muted">最近見た文書検索「<%= @recent_documents_query %>」に一致する文書は、最近表示された最大 20 件内にありません。検索語を変えるか、案件一覧から文書を探してください。</p>
    <% else %>
      <p class="muted">最近表示された最大 20 件内に条件と一致する文書はありません。検索語を変えるか、案件一覧から文書を探してください。</p>
    <% end %>
  <% else %>
    <p class="muted">文書を開くと、最近見た文書としてここに表示されます。</p>
  <% end %>
</section>

<p><%= link_to "案件一覧へ戻る", projects_path %></p>
