<% page_title "文書ショートカット" %>
<% bookmark_project_filter_label = @selected_bookmark_project&.name || @bookmark_project_code %>

<h1>文書ショートカット</h1>
<p class="muted">お気に入り、後で読む、最近見た文書を最低限の一覧で表示します。</p>

<section class="card">
  <h2>保存済みショートカットの絞り込み</h2>
  <%= form_with url: document_bookmarks_path, method: :get, local: true do |form| %>
    <div class="form-grid">
      <div class="field">
        <%= form.label :project_code, "案件" %>
        <%= form.select :project_code,
              options_for_select(@bookmark_project_options.map { |project| [project.name, project.code] }, @bookmark_project_code),
              { include_blank: "すべての案件" } %>
      </div>
      <div class="form-actions">
        <%= form.submit "絞り込む", class: "button" %>
        <% if @bookmark_project_filter_active %>
          <%= link_to "解除", document_bookmarks_path, class: "button secondary" %>
        <% end %>
      </div>
    </div>
  <% end %>
  <% if @bookmark_project_filter_active %>
    <% if @selected_bookmark_project %>
      <p class="muted">案件「<%= @selected_bookmark_project.name %>」でお気に入りと後で読むを絞り込んでいます。最近見た文書は絞り込み対象外です。</p>
    <% else %>
      <p class="muted">指定した案件では保存済みショートカットが見つかりません。最近見た文書は絞り込み対象外です。</p>
    <% end %>
  <% else %>
    <p class="muted">明示的に保存したお気に入りと後で読むだけを案件で絞り込めます。</p>
  <% end %>
</section>

<section class="card">
  <h2>お気に入り <span class="muted"><%= @favorite_bookmarks.size %>件</span></h2>
  <p class="muted">よく開く文書をここからすぐ確認できます。</p>
  <% if @favorite_bookmarks.any? %>
    <ul class="resource-list">
      <% @favorite_bookmarks.each do |bookmark| %>
        <li class="resource-list__item">
          <div class="resource-list__content">
            <strong><%= link_to bookmark.document.title, project_document_path(bookmark.document.project, bookmark.document.slug) %></strong>
            <div class="resource-list__meta">
              <span class="muted"><%= bookmark.document.project.name %></span>
              <span class="badge">よく開く文書</span>
            </div>
          </div>
          <div class="resource-list__actions">
            <%= button_to "解除", document_bookmark_path(bookmark), method: :delete, class: "button secondary" %>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <% if @bookmark_project_filter_active %>
      <p class="muted">案件「<%= bookmark_project_filter_label %>」ではお気に入りが見つかりません。</p>
    <% else %>
      <p class="muted">文書画面でお気に入りに追加すると、ここに表示されます。</p>
    <% end %>
  <% end %>
</section>

<section class="card">
  <h2>後で読む <span class="muted"><%= @read_later_bookmarks.size %>件</span></h2>
  <p class="muted">あとで確認したい文書を一時的に集めておけます。</p>
  <% if @read_later_bookmarks.any? %>
    <ul class="resource-list">
      <% @read_later_bookmarks.each do |bookmark| %>
        <li class="resource-list__item">
          <div class="resource-list__content">
            <strong><%= link_to bookmark.document.title, project_document_path(bookmark.document.project, bookmark.document.slug) %></strong>
            <div class="resource-list__meta">
              <span class="muted"><%= bookmark.document.project.name %></span>
              <span class="badge">あとで確認</span>
            </div>
          </div>
          <div class="resource-list__actions">
            <%= button_to "お気に入りへ移す", move_to_favorite_document_bookmark_path(bookmark), method: :post, class: "button" %>
            <%= button_to "解除", document_bookmark_path(bookmark), method: :delete, class: "button secondary" %>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <% if @bookmark_project_filter_active %>
      <p class="muted">案件「<%= bookmark_project_filter_label %>」では後で読む文書が見つかりません。</p>
    <% else %>
      <p class="muted">文書画面で後で読むに追加すると、ここに表示されます。</p>
    <% end %>
  <% end %>
</section>

<section class="card">
  <h2>最近見た文書 <span class="muted"><%= @recent_documents.size %>件</span></h2>
  <p class="muted">閲覧履歴から自動で表示されます。お気に入りや後で読むとは別の一覧です。</p>
  <% if @recent_documents.any? %>
    <ul class="resource-list">
      <% @recent_documents.each do |document| %>
        <li class="resource-list__item">
          <div class="resource-list__content">
            <strong><%= link_to document.title, project_document_path(document.project, document.slug) %></strong>
            <div class="resource-list__meta">
              <span class="muted"><%= document.project.name %></span>
              <span class="badge">最近見た文書</span>
            </div>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="muted">文書を開くと、最近見た文書としてここに表示されます。</p>
  <% end %>
</section>

<p><%= link_to "案件一覧へ戻る", projects_path %></p>