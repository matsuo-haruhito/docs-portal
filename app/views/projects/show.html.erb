<% content_for :left_content do %>
  <%= render "documents/tree", projects: @tree_projects, current_project: @project, current_document: nil %>
<% end %>

<% page_title @project.name %>
<section class="page-hero">
  <p class="eyebrow">Project Workspace</p>
  <h1><%= @project.name %></h1>
  <p class="muted">コード: <%= @project.code %></p>
  <p class="muted"><%= @project.description %></p>
  <p class="actions">
    <% if (site_version = @project.default_site_version_for(current_user)) %>
      <%= link_to "ドキュメントサイトを表示", project_site_path(@project, site_path: site_version.html_view_site_path, version_id: site_version.public_id), class: "button" %>
    <% end %>
    <%= link_to "文書一覧", project_documents_path(@project), class: "button secondary" %>
    <%= link_to "AI向けコンテキスト", project_ai_context_path(@project), class: "button secondary" %>
    <%= link_to "文書セット", project_document_sets_path(@project), class: "button secondary" %>
    <%= link_to "文書カタログ", project_document_catalogs_path(@project), class: "button secondary" %>
  </p>
</section>

<section class="dashboard-grid">
  <% if @important_documents.any? %>
    <article class="card">
      <h2>優先して確認したい資料</h2>
      <ul class="resource-list">
        <% @important_documents.each do |document| %>
          <li>
            <strong><%= link_to document.title, project_document_path(@project, document.slug) %></strong>
            <span class="badge"><%= document.importance_level %></span>
          </li>
        <% end %>
      </ul>
    </article>
  <% end %>

  <article class="card">
    <h2>資料一覧</h2>
    <ul class="resource-list">
      <% @documents.each do |document| %>
        <li>
          <strong><%= link_to document.title, project_document_path(@project, document.slug) %></strong>
          <span class="badge"><%= document.importance_level %></span>
        </li>
      <% end %>
    </ul>
  </article>
</section>

<p><%= link_to "案件一覧へ戻る", projects_path, class: "button secondary" %></p>
