<% page_title "ダッシュボード" %>

<section class="page-hero">
  <p class="eyebrow">Workspace</p>
  <h1>ダッシュボード</h1>
  <p class="muted">利用中の案件、最近触った文書、保留タスクをひとまとめにして次の操作へつなげます。</p>
  <p class="actions">
    <%= link_to "案件一覧へ", projects_path, class: "button" %>
    <%= link_to "文書ショートカット一覧", document_bookmarks_path, class: "button secondary" %>
    <% if current_user.internal? %>
      <%= link_to "確認依頼", document_approval_requests_path, class: "button secondary" %>
    <% end %>
  </p>
</section>

<section class="stats-grid">
  <article class="card metric-card">
    <p class="eyebrow">閲覧可能案件</p>
    <p class="metric-number"><%= @dashboard_stats[:project_count] %></p>
  </article>
  <article class="card metric-card">
    <p class="eyebrow">閲覧可能文書</p>
    <p class="metric-number"><%= @dashboard_stats[:document_count] %></p>
  </article>
  <article class="card metric-card">
    <p class="eyebrow">保存ショートカット</p>
    <p class="metric-number"><%= @dashboard_stats[:bookmark_count] %></p>
  </article>
  <article class="card metric-card">
    <p class="eyebrow">保留中の申請</p>
    <p class="metric-number"><%= @dashboard_stats[:pending_access_request_count] %></p>
  </article>
</section>

<section class="dashboard-grid">
  <article class="card">
    <h2>案件</h2>
    <% if @projects.any? %>
      <ul class="resource-list">
        <% @projects.each do |project| %>
          <li>
            <strong><%= link_to project.name, project_path(project) %></strong>
            <span class="muted"><%= project.code %></span>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="muted">閲覧可能な案件はありません。</p>
    <% end %>
  </article>

  <article class="card">
    <h2>お気に入り</h2>
    <% if @favorite_bookmarks.any? %>
      <ul class="resource-list">
        <% @favorite_bookmarks.each do |bookmark| %>
          <li>
            <strong><%= link_to bookmark.document.title, project_document_path(bookmark.document.project, bookmark.document.slug) %></strong>
            <span class="muted"><%= bookmark.document.project.name %></span>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="muted">お気に入りはありません。</p>
    <% end %>
  </article>

  <article class="card">
    <h2>後で読む</h2>
    <% if @read_later_bookmarks.any? %>
      <ul class="resource-list">
        <% @read_later_bookmarks.each do |bookmark| %>
          <li>
            <strong><%= link_to bookmark.document.title, project_document_path(bookmark.document.project, bookmark.document.slug) %></strong>
            <span class="muted"><%= bookmark.document.project.name %></span>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="muted">後で読む文書はありません。</p>
    <% end %>
  </article>

  <article class="card">
    <h2>最近見た文書</h2>
    <% if @recent_documents.any? %>
      <ul class="resource-list">
        <% @recent_documents.each do |document| %>
          <li>
            <strong><%= link_to document.title, project_document_path(document.project, document.slug) %></strong>
            <span class="muted"><%= document.project.name %></span>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="muted">最近見た文書はありません。</p>
    <% end %>
  </article>

  <article class="card">
    <h2>最近更新された文書</h2>
    <% if @recently_updated_documents.any? %>
      <ul class="resource-list">
        <% @recently_updated_documents.each do |document| %>
          <li>
            <strong><%= link_to document.title, project_document_path(document.project, document.slug) %></strong>
            <span class="muted"><%= document.project.name %></span>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="muted">最近更新された文書はありません。</p>
    <% end %>
  </article>

  <% if current_user.internal? %>
    <article class="card">
      <h2>社内向け導線</h2>
      <ul class="resource-list">
        <li><%= link_to "確認依頼一覧", document_approval_requests_path %></li>
        <li><%= link_to "外部送付履歴", document_delivery_logs_path %></li>
        <% if admin_user? %>
          <li><%= link_to "管理ダッシュボード", admin_root_path %></li>
        <% end %>
      </ul>
    </article>
  <% end %>
</section>
