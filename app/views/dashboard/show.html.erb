<% page_title "ダッシュボード" %>

<%
  summary_cards = [
    {
      label: "閲覧可能案件",
      count: @dashboard_stats[:project_count],
      path: projects_path,
      cta: "案件一覧へ"
    },
    {
      label: "閲覧可能文書",
      count: @dashboard_stats[:document_count],
      path: documents_path,
      cta: "文書一覧へ"
    },
    {
      label: "保存ショートカット",
      count: @dashboard_stats[:bookmark_count],
      path: document_bookmarks_path,
      cta: "ショートカット一覧へ"
    },
    {
      label: "保留中の申請",
      count: @dashboard_stats[:pending_access_request_count],
      path: access_requests_path,
      cta: "申請一覧へ",
      description: "あなたが提出したアクセス申請の保留件数です。"
    }
  ]

  if current_user.internal?
    summary_cards << {
      label: "保留中の確認依頼",
      count: @dashboard_stats[:pending_approval_count],
      path: document_approval_requests_path,
      cta: "未処理の確認依頼を見る",
      description: "社内担当者として処理する確認依頼の保留件数です。"
    }
  end
%>

<section class="page-hero">
  <h1>ダッシュボード</h1>
  <p class="muted">利用中の案件、最近触った文書、保留タスクをひとまとめにして次の操作へつなげます。</p>
  <% if !current_user.internal? && @projects.empty? && @pending_access_requests.empty? && @favorite_bookmarks.empty? && @read_later_bookmarks.empty? && @recent_documents.empty? && @recently_updated_documents.empty? %>
    <p class="muted">このダッシュボードは権限不足のエラーではありません。案件一覧・文書一覧から、現在閲覧できる範囲を確認できます。社内の確認依頼は対象になったときだけ担当者側に表示されます。</p>
  <% elsif current_user.internal? && @pending_access_requests.empty? && @dashboard_stats[:pending_approval_count].to_i.zero? %>
    <p class="muted">保留タスクがない場合も、案件や文書の一覧から現在の担当範囲を確認できます。管理画面への移動は、管理権限がある場合だけ表示されます。</p>
  <% end %>
  <p class="actions">
    <%= link_to "案件一覧へ", projects_path, class: "button", data: { turbo_frame: "_top" } %>
    <%= link_to "文書ショートカット一覧", document_bookmarks_path, class: "button secondary" %>
  </p>
</section>

<section class="stats-grid">
  <% summary_cards.each do |card| %>
    <article class="card metric-card">
      <p class="eyebrow"><%= card[:label] %></p>
      <p class="metric-number"><%= card[:count] %></p>
      <% if card[:description].present? %>
        <p class="muted"><%= card[:description] %></p>
      <% end %>
      <%= link_to card[:cta], card[:path], class: "metric-card__cta", data: { turbo_frame: "_top" } %>
    </article>
  <% end %>
</section>

<section class="dashboard-grid">
  <article class="card">
    <h2>保留中のアクセス申請</h2>
    <% if @pending_access_requests.any? %>
      <p class="muted">最近の申請を確認できます。取消や過去申請の確認は申請一覧で行います。</p>
      <ul class="resource-list">
        <% @pending_access_requests.each do |access_request| %>
          <% request_hash = AccessRequestHash.new(access_request).call %>
          <% requestable = request_hash[:requestable] %>
          <% requestable_name = requestable[:name] || requestable[:title] || requestable[:file_name] || requestable[:public_id] %>
          <li class="resource-list__item">
            <div class="resource-list__content">
              <strong><%= requestable_name %></strong>
              <span class="muted resource-list__meta"><%= requestable[:type_label] %> / <%= request_hash[:requested_access_level_label] %> / <%= request_hash[:status_label] %> / <%= l(access_request.created_at, format: :short) %></span>
            </div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="muted">保留中のアクセス申請はありません。過去の申請は申請一覧で確認できます。</p>
    <% end %>
    <p class="actions">
      <%= link_to "申請一覧で詳しく見る", access_requests_path, class: "button secondary", data: { turbo_frame: "_top" } %>
    </p>
  </article>

  <article class="card">
    <h2>案件</h2>
    <% if @projects.any? %>
      <ul class="resource-list">
        <% @projects.each do |project| %>
          <li class="resource-list__item">
            <div class="resource-list__content">
              <strong><%= link_to project.name, project_path(project), data: { turbo_frame: "_top" } %></strong>
              <span class="muted resource-list__meta"><%= project.code %></span>
            </div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="muted">閲覧可能な案件はありません。参加中の案件は案件一覧で確認できます。</p>
      <p><%= link_to "案件一覧へ", projects_path, class: "metric-card__cta", data: { turbo_frame: "_top" } %></p>
    <% end %>
  </article>

  <article class="card">
    <h2>お気に入り</h2>
    <% if @favorite_bookmarks.any? %>
      <ul class="resource-list">
        <% @favorite_bookmarks.each do |bookmark| %>
          <li class="resource-list__item">
            <div class="resource-list__content">
              <strong><%= link_to bookmark.document.title, project_document_path(bookmark.document.project, bookmark.document.slug), data: { turbo_frame: "_top" } %></strong>
              <span class="muted resource-list__meta"><%= bookmark.document.project.name %></span>
            </div>
          </li>
        <% end %>
      </ul>
      <p class="actions">
        <%= link_to "ショートカット一覧でさらに見る", document_bookmarks_path, class: "button secondary", data: { turbo_frame: "_top" } %>
      </p>
    <% else %>
      <p class="muted">お気に入りはまだ保存されていません。これは閲覧権限がない状態ではなく、個人用ショートカットが未利用の状態です。文書一覧から文書を開き、詳細画面でお気に入りに追加できます。</p>
      <p><%= link_to "文書一覧へ", documents_path, class: "metric-card__cta", data: { turbo_frame: "_top" } %></p>
    <% end %>
  </article>

  <article class="card">
    <h2>後で読む</h2>
    <% if @read_later_bookmarks.any? %>
      <ul class="resource-list">
        <% @read_later_bookmarks.each do |bookmark| %>
          <li class="resource-list__item">
            <div class="resource-list__content">
              <strong><%= link_to bookmark.document.title, project_document_path(bookmark.document.project, bookmark.document.slug), data: { turbo_frame: "_top" } %></strong>
              <span class="muted resource-list__meta"><%= bookmark.document.project.name %></span>
            </div>
          </li>
        <% end %>
      </ul>
      <p class="actions">
        <%= link_to "ショートカット一覧でさらに見る", document_bookmarks_path, class: "button secondary", data: { turbo_frame: "_top" } %>
      </p>
    <% else %>
      <p class="muted">後で読む文書はまだ保存されていません。これは閲覧権限がない状態ではなく、個人用ショートカットが未利用の状態です。あとで確認したい文書は、文書一覧から開いて後で読むに追加できます。</p>
      <p><%= link_to "文書一覧へ", documents_path, class: "metric-card__cta", data: { turbo_frame: "_top" } %></p>
    <% end %>
  </article>

  <article class="card">
    <h2>最近見た文書</h2>
    <% if @recent_documents.any? %>
      <p class="muted">あなたの閲覧履歴から表示しています。更新通知ではなく、作業再開用の個人履歴です。</p>
      <ul class="resource-list">
        <% @recent_documents.each do |document| %>
          <li class="resource-list__item">
            <div class="resource-list__content">
              <strong><%= link_to document.title, project_document_path(document.project, document.slug), data: { turbo_frame: "_top" } %></strong>
              <span class="muted resource-list__meta"><%= document.project.name %> / あなたが最近閲覧</span>
            </div>
          </li>
        <% end %>
      </ul>
      <p class="actions">
        <%= link_to "文書一覧でさらに探す", documents_path, class: "button secondary", data: { turbo_frame: "_top" } %>
      </p>
    <% else %>
      <p class="muted">このアカウントでは最近見た文書がまだありません。文書一覧から読み始めると、直近の閲覧履歴がここに表示されます。権限不足やエラーではなく、まだ閲覧履歴がない状態です。</p>
      <p><%= link_to "文書一覧へ", documents_path, class: "metric-card__cta", data: { turbo_frame: "_top" } %></p>
    <% end %>
  </article>

  <article class="card">
    <h2>最近更新された文書</h2>
    <% if @recently_updated_documents.any? %>
      <p class="muted">閲覧可能な文書を更新日時の新しい順に表示しています。未読通知ではなく、更新候補を確認する入口です。</p>
      <ul class="resource-list">
        <% @recently_updated_documents.each do |document| %>
          <li class="resource-list__item">
            <div class="resource-list__content">
              <strong><%= link_to document.title, project_document_path(document.project, document.slug), data: { turbo_frame: "_top" } %></strong>
              <span class="muted resource-list__meta"><%= document.project.name %> / 更新日時 <%= l(document.updated_at, format: :short) %></span>
            </div>
          </li>
        <% end %>
      </ul>
      <p class="actions">
        <%= link_to "文書一覧でさらに探す", documents_path, class: "button secondary", data: { turbo_frame: "_top" } %>
      </p>
    <% else %>
      <p class="muted">最近更新された文書はありません。閲覧可能な文書は文書一覧から確認できます。権限エラーではなく、閲覧可能な範囲に更新候補がない状態です。</p>
      <p><%= link_to "文書一覧へ", documents_path, class: "metric-card__cta", data: { turbo_frame: "_top" } %></p>
    <% end %>
  </article>

  <% if current_user.internal? %>
    <article class="card">
      <h2>受付中Q&amp;A候補</h2>
      <p class="muted">公開Q&amp;Aのうち受付中の root thread を最大 5 件だけ表示します。全件一覧、通知、SLA、回答期限、担当割当を示すものではありません。確認はリンク先の各文書または版のQ&amp;A workspaceで行います。</p>
      <% if @open_question_handoff_threads.any? %>
        <ul class="resource-list">
          <% @open_question_handoff_threads.each do |thread| %>
            <% document = thread.document %>
            <% latest_activity_at = ([thread.updated_at] + thread.replies.map(&:updated_at)).compact.max %>
            <% confirmation_path = thread.document_version.present? ? document_version_path(thread.document_version, comment_tab: "qa") : project_document_path(document.project, document.slug, comment_tab: "qa") %>
            <li class="resource-list__item">
              <div class="resource-list__content">
                <strong><%= link_to document.title, confirmation_path, data: { turbo_frame: "_top" } %></strong>
                <span class="muted resource-list__meta">
                  <%= document.project.name %>（<%= document.project.code %>）
                  <% if thread.document_version.present? %>
                    / 版 <%= thread.document_version.version_label %>
                  <% end %>
                  / 投稿者 <%= thread.author.display_name %>
                  / <%= thread.replies.any? ? "返信あり" : "返信なし" %>
                  / 最終活動 <%= l(latest_activity_at, format: :short) %>
                </span>
                <span class="muted resource-list__meta"><%= truncate(strip_tags(thread.body).squish, length: 120) %></span>
              </div>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="muted">受付中Q&amp;A候補はありません。この表示は通知 green、SLA 達成、問い合わせが存在しない保証ではありません。必要に応じて各文書のQ&amp;A workspaceを確認してください。</p>
      <% end %>
    </article>

    <article class="card">
      <h2>社内向け導線</h2>
      <p class="muted">確認依頼、外部送付履歴、管理画面などの社内運用画面への入口です。</p>
      <ul class="resource-list">
        <li class="resource-list__item">
          <div class="resource-list__content"><%= link_to "確認依頼一覧", document_approval_requests_path %></div>
        </li>
        <li class="resource-list__item">
          <div class="resource-list__content"><%= link_to "外部送付履歴", document_delivery_logs_path %></div>
        </li>
        <% if admin_user? %>
          <li class="resource-list__item">
            <div class="resource-list__content"><%= link_to "管理ダッシュボード", admin_root_path %></div>
          </li>
        <% end %>
      </ul>
    </article>
  <% end %>
</section>
