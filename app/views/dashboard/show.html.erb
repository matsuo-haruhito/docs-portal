<% page_title "ダッシュボード" %>

<%
  summary_cards = [
    {
      label: "閲覧可能案件",
      count: @dashboard_stats[:project_count],
      path: projects_path,
      cta: "案件一覧へ"
    },
    {
      label: "閲覧可能文書",
      count: @dashboard_stats[:document_count],
      path: documents_path,
      cta: "文書一覧へ"
    },
    {
      label: "保存ショートカット",
      count: @dashboard_stats[:bookmark_count],
      path: document_bookmarks_path,
      cta: "ショートカット一覧へ"
    },
    {
      label: "保留中の申請",
      count: @dashboard_stats[:pending_access_request_count],
      path: access_requests_path,
      cta: "申請一覧へ"
    }
  ]

  if current_user.internal?
    summary_cards << {
      label: "保留中の確認依頼",
      count: @dashboard_stats[:pending_approval_count],
      path: document_approval_requests_path,
      cta: "未処理の確認依頼を見る"
    }
  end
%>

<section class="page-hero">
  <h1>ダッシュボード</h1>
  <p class="muted">利用中の案件、最近触った文書、保留タスクをひとまとめにして次の操作へつなげます。</p>
  <p class="actions">
    <%= link_to "案件一覧へ", projects_path, class: "button", data: { turbo_frame: "_top" } %>
    <%= link_to "文書ショートカット一覧", document_bookmarks_path, class: "button secondary" %>
  </p>
</section>

<section class="stats-grid">
  <% summary_cards.each do |card| %>
    <article class="card metric-card">
      <p class="eyebrow"><%= card[:label] %></p>
      <p class="metric-number"><%= card[:count] %></p>
      <%= link_to card[:cta], card[:path], class: "metric-card__cta", data: { turbo_frame: "_top" } %>
    </article>
  <% end %>
</section>

<section class="dashboard-grid">
  <article class="card">
    <h2>案件</h2>
    <% if @projects.any? %>
      <ul class="resource-list">
        <% @projects.each do |project| %>
          <li>
            <strong><%= link_to project.name, project_path(project), data: { turbo_frame: "_top" } %></strong>
            <span class="muted"><%= project.code %></span>
          </li>
        <% end %>
      </ul>
    <% else %>
      <div class="dashboard-empty-state">
        <p class="muted">閲覧可能な案件はありません。案件一覧で参加中の案件を確認できます。</p>
        <p class="dashboard-empty-state__actions">
          <%= link_to "案件一覧へ", projects_path, class: "dashboard-empty-state__link", data: { turbo_frame: "_top" } %>
        </p>
      </div>
    <% end %>
  </article>

  <article class="card">
    <h2>お気に入り</h2>
    <% if @favorite_bookmarks.any? %>
      <ul class="resource-list">
        <% @favorite_bookmarks.each do |bookmark| %>
          <li>
            <strong><%= link_to bookmark.document.title, project_document_path(bookmark.document.project, bookmark.document.slug), data: { turbo_frame: "_top" } %></strong>
            <span class="muted"><%= bookmark.document.project.name %></span>
          </li>
        <% end %>
      </ul>
    <% else %>
      <div class="dashboard-empty-state">
        <p class="muted">お気に入りはありません。文書を見つけたら、詳細画面からお気に入りに追加できます。</p>
        <p class="dashboard-empty-state__actions">
          <%= link_to "文書一覧へ", documents_path, class: "dashboard-empty-state__link", data: { turbo_frame: "_top" } %>
          <%= link_to "ショートカット一覧へ", document_bookmarks_path, class: "dashboard-empty-state__link" %>
        </p>
      </div>
    <% end %>
  </article>

  <article class="card">
    <h2>後で読む</h2>
    <% if @read_later_bookmarks.any? %>
      <ul class="resource-list">
        <% @read_later_bookmarks.each do |bookmark| %>
          <li>
            <strong><%= link_to bookmark.document.title, project_document_path(bookmark.document.project, bookmark.document.slug), data: { turbo_frame: "_top" } %></strong>
            <span class="muted"><%= bookmark.document.project.name %></span>
          </li>
        <% end %>
      </ul>
    <% else %>
      <div class="dashboard-empty-state">
        <p class="muted">後で読む文書はありません。あとで確認したい文書は、詳細画面から後で読むに追加できます。</p>
        <p class="dashboard-empty-state__actions">
          <%= link_to "文書一覧へ", documents_path, class: "dashboard-empty-state__link", data: { turbo_frame: "_top" } %>
          <%= link_to "ショートカット一覧へ", document_bookmarks_path, class: "dashboard-empty-state__link" %>
        </p>
      </div>
    <% end %>
  </article>

  <article class="card">
    <h2>最近見た文書</h2>
    <% if @recent_documents.any? %>
      <ul class="resource-list">
        <% @recent_documents.each do |document| %>
          <li>
            <strong><%= link_to document.title, project_document_path(document.project, document.slug), data: { turbo_frame: "_top" } %></strong>
            <span class="muted"><%= document.project.name %></span>
          </li>
        <% end %>
      </ul>
    <% else %>
      <div class="dashboard-empty-state">
        <p class="muted">最近見た文書はありません。文書一覧から読み始めると、直近の閲覧履歴がここに表示されます。</p>
        <p class="dashboard-empty-state__actions">
          <%= link_to "文書一覧へ", documents_path, class: "dashboard-empty-state__link", data: { turbo_frame: "_top" } %>
        </p>
      </div>
    <% end %>
  </article>

  <article class="card">
    <h2>最近更新された文書</h2>
    <% if @recently_updated_documents.any? %>
      <ul class="resource-list">
        <% @recently_updated_documents.each do |document| %>
          <li>
            <strong><%= link_to document.title, project_document_path(document.project, document.slug), data: { turbo_frame: "_top" } %></strong>
            <span class="muted"><%= document.project.name %></span>
          </li>
        <% end %>
      </ul>
    <% else %>
      <div class="dashboard-empty-state">
        <p class="muted">最近更新された文書はありません。閲覧可能な文書は文書一覧から確認できます。</p>
        <p class="dashboard-empty-state__actions">
          <%= link_to "文書一覧へ", documents_path, class: "dashboard-empty-state__link", data: { turbo_frame: "_top" } %>
        </p>
      </div>
    <% end %>
  </article>

  <% if current_user.internal? %>
    <article class="card">
      <h2>社内向け導線</h2>
      <ul class="resource-list">
        <li><%= link_to "確認依頼一覧", document_approval_requests_path %></li>
        <li><%= link_to "外部送付履歴", document_delivery_logs_path %></li>
        <% if admin_user? %>
          <li><%= link_to "管理ダッシュボード", admin_root_path %></li>
        <% end %>
      </ul>
    </article>
  <% end %>
</section>