- page_title "確認依頼"

h1 確認依頼

- if @document.present?
  p.muted
    = link_to @project.name, project_path(@project)
    |  /
    = link_to @document.title, project_document_path(@project, @document.slug)

- if @document_approval_requests.any?
  table
    thead
      tr
        th 日時
        th 文書名
        th 依頼名
        th 依頼者
        th 確認相手
        th 状態
    tbody
      - @document_approval_requests.each do |request|
        tr
          td = request.created_at.strftime("%Y-%m-%d %H:%M")
          td = link_to request.document.title, project_document_path(request.document.project, request.document.slug)
          td = link_to request.title, document_approval_request_path(request)
          td = request.requester.name
          td = request.approver&.name || "-"
          td = document_approval_request_status_label(request)
- else
  p.muted 確認依頼はありません。
