<% current_project = local_assigns[:current_project] || local_assigns[:current_document]&.project %>
<% current_document = local_assigns[:current_document] %>
<% render_state = local_assigns[:render_state] %>
<% tree_projects = Array(local_assigns[:projects]) %>
<% if render_state.blank? && tree_projects.present? %>
  <% render_state = document_tree_render_state(
    projects: tree_projects,
    current_project:,
    current_document:,
    expanded_source_path: local_assigns[:expanded_source_path],
    collapsed_source_path: local_assigns[:collapsed_source_path]
  ) %>
<% end %>
<% expand_all_path = document_tree_toggle_all_path(:expanded, current_project:, current_document:) %>
<% collapse_all_path = document_tree_toggle_all_path(:collapsed, current_project:, current_document:) %>

<div id="document_tree_toolbar" class="document-tree-toolbar">
  <div class="document-tree-toolbar__title-row">
    <h2>文書ツリー</h2>
  </div>
  <% if current_project.present? && render_state.present? %>
    <div class="document-tree-toolbar__action-row">
      <div class="tree-view-toolbar" aria-label="文書ツリー操作">
        <% if expand_all_path.present? %>
          <%= button_to "案件の文書ツリーを開く", expand_all_path, method: :post, form: { data: { turbo_stream: true }, title: "現在開いている案件の文書ツリーを全て展開します" }, class: "document-tree-action-link" %>
        <% end %>
        <% if collapse_all_path.present? %>
          <%= button_to "案件の文書ツリーを閉じる", collapse_all_path, method: :post, form: { data: { turbo_stream: true }, title: "現在開いている案件の文書ツリーを全て閉じます" }, class: "document-tree-action-link" %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>