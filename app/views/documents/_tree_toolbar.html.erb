<% current_project = local_assigns[:current_project] || local_assigns[:current_document]&.project %>
<% current_document = local_assigns[:current_document] %>
<% render_state = local_assigns[:render_state] %>
<% tree_projects = Array(local_assigns[:projects]) %>
<% tree_window_offset = document_tree_window_request_offset %>
<% tree_query = document_tree_query %>
<% tree_filter_path = current_project.present? ? project_document_tree_path(current_project, document_slug: current_document&.slug, format: :turbo_stream) : nil %>
<% if render_state.blank? && tree_projects.present? %>
  <% render_state = document_tree_render_state(
    projects: tree_projects,
    current_project:,
    current_document:,
    expanded_source_path: local_assigns[:expanded_source_path],
    collapsed_source_path: local_assigns[:collapsed_source_path]
  ) %>
<% end %>

<div id="document_tree_toolbar" class="document-tree-toolbar">
  <div class="document-tree-toolbar__title-row">
    <h2>文書ツリー</h2>
  </div>
  <% if current_project.present? %>
    <div class="document-tree-toolbar__search-row">
      <%= form_with url: tree_filter_path, method: :get, class: "document-tree-toolbar__search-form", data: { turbo_stream: true } do |form| %>
        <%= form.search_field :tree_query, value: tree_query, placeholder: "文書名・slug・元パスで絞り込む", class: "document-tree-toolbar__search-input", "aria-label": "文書名・slug・元パスで絞り込む" %>
        <%= form.submit "絞り込む", class: "document-tree-action-link" %>
        <% if tree_query.present? %>
          <%= link_to "解除", tree_filter_path, class: "document-tree-action-link", data: { turbo_stream: true } %>
        <% end %>
      <% end %>
    </div>
    <div class="document-tree-toolbar__action-row">
      <% if render_state.present? %>
        <%= tree_view_toolbar(
          render_state,
          labels: {
            expand_all: "案件の文書ツリーを開く",
            collapse_all: "案件の文書ツリーを閉じる"
          },
          button_class_name: "document-tree-action-link"
        ) %>
      <% else %>
        <div class="document-tree-actions" aria-label="文書ツリー操作">
          <%= button_to "案件の文書ツリーを開く", document_tree_all_project_path(current_project, tree_action: "show", tree_query:, tree_window_offset:, format: :turbo_stream), method: :post, form: { data: { turbo_stream: true }, title: "現在開いている案件の文書ツリーを全て展開します" }, class: "document-tree-action-link" %>
          <%= button_to "案件の文書ツリーを閉じる", document_tree_all_project_path(current_project, tree_action: "hide", tree_query:, tree_window_offset:, format: :turbo_stream), method: :post, form: { data: { turbo_stream: true }, title: "現在開いている案件の文書ツリーを全て閉じます" }, class: "document-tree-action-link" %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
