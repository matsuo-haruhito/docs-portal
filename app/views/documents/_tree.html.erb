<div id="document_tree_panel">
  <%= turbo_stream_from "document_tree" %>

  <style>
    .document-tree-toolbar { display: grid; gap: 8px; min-width: 0; width: 100%; }
    .document-tree-toolbar__title-row { display: flex; align-items: center; min-width: 0; }
    .document-tree-toolbar h2 { margin: 0; line-height: 1.2; white-space: nowrap; }
    .document-tree-toolbar__search-row { min-width: 0; }
    .document-tree-toolbar__search-form { display: flex; flex-wrap: wrap; gap: 6px; min-width: 0; }
    .document-tree-toolbar__search-input { flex: 1 1 220px; min-width: 0; border: 1px solid rgba(15, 23, 42, 0.16); border-radius: 999px; padding: 6px 10px; font: inherit; }
    .document-tree-toolbar__action-row { display: flex; justify-content: flex-end; min-width: 0; }
    .document-tree-actions { display: inline-flex; flex-direction: row; flex-wrap: wrap; align-items: center; justify-content: flex-end; gap: 6px; min-width: 0; }
    .document-tree-actions form { margin: 0; }
    .document-tree-action-link { display: inline-flex; align-items: center; justify-content: center; border: 1px solid rgba(15, 98, 254, 0.32); border-radius: 999px; padding: 2px 8px; font-size: 12px; line-height: 1.5; background: #fff; color: #0f62fe; cursor: pointer; font: inherit; white-space: nowrap; }
    .document-tree-action-link:hover, .document-tree-action-link:focus { background: #eff6ff; }
    @media (max-width: 520px) {
      .document-tree-toolbar__search-form { flex-direction: column; }
      .document-tree-toolbar__search-input { flex-basis: auto; width: 100%; }
      .document-tree-toolbar__action-row { justify-content: stretch; }
      .document-tree-actions { flex-direction: column; align-items: stretch; gap: 4px; width: 100%; }
      .document-tree-action-link { width: 100%; }
    }
    .tree-item-status-icon { display: inline-flex; align-items: center; justify-content: center; margin-left: 4px; font-size: 0.85em; line-height: 1; vertical-align: middle; }
    .tree-item-status-icon--warning { opacity: 0.9; }
    .tree-item-status-icon--unread { font-size: 0.78em; }
    .tree-item-label.tree-label--length-gt-15 { font-size: calc(1em - 1.5pt); }
    .tree-item-label.tree-label--length-gt-20 { font-size: calc(1em - 2pt); }
    .tree-item-label.tree-label--length-gt-25 { font-size: calc(1em - 2.5pt); }
    .document-tree-end-spacer { pointer-events: none; }
    .document-tree-end-spacer > td {
      height: 3rem;
      padding: 0 !important;
      border: 0 !important;
      background: transparent !important;
      line-height: 0;
    }
    .document-tree-filter-summary { margin-bottom: 8px; }
    .document-tree-window-controls { display: grid; gap: 6px; margin-top: 8px; }
    .document-tree-window-summary { margin: 0; }
    @media (max-width: 520px) {
      .document-tree-end-spacer > td { height: 1.5rem; }
    }
  </style>

  <% tree_projects = Array(projects) %>
  <% render_state = nil %>
  <% if tree_projects.present? %>
    <% render_state = document_tree_render_state(
      projects: tree_projects,
      current_project: local_assigns[:current_project],
      current_document: local_assigns[:current_document],
      expanded_source_path: local_assigns[:expanded_source_path],
      collapsed_source_path: local_assigns[:collapsed_source_path]
    ) %>
  <% end %>

  <% content_for :sidebar_toolbar do %>
    <%= render "documents/tree_toolbar",
      current_project: local_assigns[:current_project],
      current_document: local_assigns[:current_document],
      projects: tree_projects,
      render_state: render_state,
      expanded_source_path: local_assigns[:expanded_source_path],
      collapsed_source_path: local_assigns[:collapsed_source_path] %>
  <% end %>

  <p class="muted">案件と文書の階層を表示します。</p>

  <% if tree_projects.empty? %>
    <p class="muted">表示できる案件はありません。</p>
  <% else %>
    <% tree_query = document_tree_query %>
    <% query_match_count = tree_query.present? ? document_tree_query_match_count(tree_projects, current_project: local_assigns[:current_project], current_document: local_assigns[:current_document]) : nil %>
    <% window = document_tree_render_window(render_state, current_document: local_assigns[:current_document]) %>
    <% window_project = local_assigns[:current_project] || local_assigns[:current_document]&.project %>

    <% if tree_query.present? %>
      <% if query_match_count.to_i.positive? %>
        <p class="muted document-tree-filter-summary">「<%= tree_query %>」に一致する文書を <%= query_match_count %> 件表示しています。</p>
      <% else %>
        <p class="muted document-tree-filter-summary">「<%= tree_query %>」に一致する文書はありません。文書名、slug、元パスで絞り込めます。</p>
      <% end %>
    <% end %>

    <% if tree_query.blank? || query_match_count.to_i.positive? %>
      <div class="document-tree-scroll-spacer">
        <table class="tree-view-table">
          <tbody>
            <%= window ? tree_view_rows(render_state, window:) : tree_view_rows(render_state) %>
            <tr class="document-tree-end-spacer" aria-hidden="true">
              <td colspan="99"></td>
            </tr>
          </tbody>
        </table>
      </div>
    <% end %>

    <% if window.present? && (tree_query.blank? || query_match_count.to_i.positive?) %>
      <div class="document-tree-window-controls" aria-label="文書ツリー表示範囲">
        <p class="muted document-tree-window-summary">大きなツリーのため <%= window.start_index + 1 %>-<%= window.end_index %> / <%= window.total_count %> 行を表示しています。</p>
        <% if window_project.present? %>
          <div class="document-tree-actions">
            <% if window.previous? %>
              <%= button_to "前の#{DocumentsHelper::DOCUMENT_TREE_RENDER_WINDOW_LIMIT}行", document_tree_window_path(project: window_project, current_document: local_assigns[:current_document], offset: window.previous_offset), method: :get, form: { data: { turbo_stream: true } }, class: "document-tree-action-link" %>
            <% end %>
            <% if window.next? %>
              <%= button_to "次の#{DocumentsHelper::DOCUMENT_TREE_RENDER_WINDOW_LIMIT}行", document_tree_window_path(project: window_project, current_document: local_assigns[:current_document], offset: window.next_offset), method: :get, form: { data: { turbo_stream: true } }, class: "document-tree-action-link" %>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>
  <% end %>
</div>
