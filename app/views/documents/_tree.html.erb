<div id="document_tree_panel">
  <%= turbo_stream_from "document_tree" %>

  <style>
    .document-tree-heading { display: flex; align-items: flex-start; justify-content: space-between; gap: 8px; margin-top: 0; }
    .document-tree-heading h2 { margin: 0; }
    .document-tree-actions { display: inline-flex; flex-direction: column; align-items: stretch; gap: 4px; flex-shrink: 0; }
    .document-tree-actions form { margin: 0; }
    .document-tree-action-link { display: inline-flex; align-items: center; justify-content: center; border: 1px solid rgba(15, 98, 254, 0.32); border-radius: 999px; padding: 2px 8px; font-size: 12px; line-height: 1.5; background: #fff; color: #0f62fe; cursor: pointer; font: inherit; white-space: nowrap; width: 100%; }
    .document-tree-action-link:hover, .document-tree-action-link:focus { background: #eff6ff; }
    .tree-item-status-icon { display: inline-flex; align-items: center; justify-content: center; margin-left: 4px; font-size: 0.85em; line-height: 1; vertical-align: middle; }
    .tree-item-status-icon--warning { opacity: 0.9; }
    .tree-item-status-icon--unread { font-size: 0.78em; }
    .tree-item-label.tree-label--length-gt-15 { font-size: calc(1em - 1.5pt); }
    .tree-item-label.tree-label--length-gt-20 { font-size: calc(1em - 2pt); }
    .tree-item-label.tree-label--length-gt-25 { font-size: calc(1em - 2.5pt); }
  </style>

  <% current_project = local_assigns[:current_project] || local_assigns[:current_document]&.project %>

  <div class="document-tree-heading">
    <h2>文書ツリー</h2>
    <% if current_project.present? %>
      <div class="document-tree-actions" aria-label="文書ツリー操作">
        <%= button_to "案件の文書ツリーを開く", document_tree_all_project_path(current_project, tree_action: "show", format: :turbo_stream), method: :post, form: { data: { turbo_stream: true }, title: "現在開いている案件の文書ツリーを全て展開します" }, class: "document-tree-action-link" %>
        <%= button_to "案件の文書ツリーを閉じる", document_tree_all_project_path(current_project, tree_action: "hide", format: :turbo_stream), method: :post, form: { data: { turbo_stream: true }, title: "現在開いている案件の文書ツリーを全て閉じます" }, class: "document-tree-action-link" %>
      </div>
    <% end %>
  </div>
  <p class="muted">案件と文書の階層を表示します。</p>

  <% tree_projects = Array(projects) %>
  <% if tree_projects.empty? %>
    <p class="muted">表示できる案件はありません。</p>
  <% else %>
    <% render_state = document_tree_render_state(
      projects: tree_projects,
      current_project: local_assigns[:current_project],
      current_document: local_assigns[:current_document],
      expanded_source_path: local_assigns[:expanded_source_path],
      collapsed_source_path: local_assigns[:collapsed_source_path]
    ) %>

    <div class="document-tree-scroll-spacer" style="padding-bottom: 3.5rem;">
      <table class="tree-view-table">
        <tbody>
          <%= tree_view_rows(render_state) %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>
