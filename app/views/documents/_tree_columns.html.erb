<% tree_open_path = case item
  when Project
    project_document_tree_path(item, node_id: item.id, tree_action: "show", format: :turbo_stream)
  when DocumentsHelper::DocumentTreeFolderNode
    project_document_tree_path(item.project, tree_action: "show", source_path: item.path, format: :turbo_stream)
  end %>

<td class="<%= tree_item_css_class(item) %>">
  <%= link_to tree_item_label(item),
    tree_item_path(item),
    data: {
      turbo_frame: "main_panel",
      tree_nav_link: true,
      tree_item_type: item.is_a?(DocumentsHelper::DocumentTreeFolderNode) ? "document_tree_folder" : item.class.name.underscore,
      tree_open_url: tree_open_path
    } %>

  <% if item.is_a?(Document) %>
    <% if (updated_label = tree_item_updated_label(item)) %>
      <span class="muted tree-item-meta">更新: <%= updated_label %></span>
    <% end %>

    <% unless tree_item_html_available?(item) %>
      <span class="muted tree-item-meta">HTML未生成</span>
    <% end %>

    <%= link_to "詳細", tree_item_detail_path(item), class: "tree-item-detail-link", data: { turbo_frame: "main_panel" } %>
  <% elsif item.is_a?(DocumentsHelper::DocumentTreeFolderNode) %>
    <span class="muted tree-item-meta">フォルダ</span>
  <% elsif item.is_a?(Project) %>
    <%= link_to "案件トップ", tree_item_detail_path(item), class: "tree-item-detail-link", data: { turbo_frame: "main_panel" } %>
  <% end %>
</td>
