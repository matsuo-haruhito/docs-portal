<!DOCTYPE html>
<html>
  <head>
    <title><%= [content_for(:title), "Document Portal Sample"].compact_blank.join(" | ") %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tree_view", media: "all" %>
    <style>
      body { font-family: system-ui, sans-serif; margin: 0; background: #fafafa; color: #222; }
      header { background: #1f2937; color: white; padding: 12px 20px; }
      header nav { max-width: 1200px; margin: 0 auto; display: flex; gap: 16px; align-items: center; justify-content: space-between; }
      .brand-link { color: white; font-weight: 700; font-size: 18px; }
      .header-links { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
      .user-menu { display: flex; align-items: center; gap: 10px; }
      main { max-width: 1000px; margin: 24px auto; background: white; padding: 24px; border-radius: 12px; box-shadow: 0 1px 8px rgba(0,0,0,.08); }
      .layout-with-sidebar { max-width: 1200px; margin: 24px auto; display: grid; gap: 24px; grid-template-columns: 300px minmax(0, 1fr); align-items: start; }
      .sidebar-panel { background: white; padding: 20px; border-radius: 12px; box-shadow: 0 1px 8px rgba(0,0,0,.08); position: sticky; top: 24px; }
      .main-panel { background: white; padding: 24px; border-radius: 12px; box-shadow: 0 1px 8px rgba(0,0,0,.08); min-width: 0; }
      a { color: #0f62fe; text-decoration: none; }
      header a { color: #bfdbfe; }
      table { width: 100%; border-collapse: collapse; margin-top: 16px; }
      th, td { border-bottom: 1px solid #ddd; text-align: left; padding: 10px 8px; }
      input, select, textarea { width: 100%; box-sizing: border-box; padding: 8px; margin-top: 4px; }
      textarea { min-height: 96px; }
      form { margin: 0; }
      .form-grid { display: grid; gap: 16px; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); }
      .actions { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }
      .button, button { display: inline-block; border: 1px solid #0f62fe; background: #0f62fe; color: white; border-radius: 8px; padding: 8px 12px; cursor: pointer; }
      .button.secondary { background: white; color: #0f62fe; }
      .button.danger { background: #dc2626; border-color: #dc2626; }
      header .button.secondary { border-color: #bfdbfe; color: #bfdbfe; background: transparent; }
      .card { border: 1px solid #e5e7eb; border-radius: 12px; padding: 16px; margin-bottom: 24px; }
      .muted { color: #666; }
      .badge { display: inline-block; padding: 2px 8px; border-radius: 999px; background: #eef2ff; color: #4338ca; font-size: 12px; }
      .notice { padding: 12px 16px; border-radius: 10px; margin-bottom: 16px; }
      .notice.alert { background: #fee2e2; color: #991b1b; }
      .notice.ok { background: #dcfce7; color: #166534; }
      .nav-list { display: flex; gap: 12px; flex-wrap: wrap; margin: 0 0 20px; padding: 0; list-style: none; }
      .nav-list a { display: inline-block; padding: 8px 12px; border-radius: 999px; background: #eff6ff; }
      .error-messages { background: #fff7ed; color: #9a3412; border: 1px solid #fdba74; border-radius: 10px; padding: 12px 16px; margin-bottom: 16px; }
      ul { line-height: 1.6; }
      .tree-view-table td { border-bottom: none; padding: 6px 8px; }
      .tree-view-table .current-node a { font-weight: 700; color: #1d4ed8; }
      .tree-item-meta { display: inline-block; margin-left: 6px; font-size: 12px; }
      .tree-item-detail-link { display: inline-block; margin-left: 6px; font-size: 12px; }
      .tree-view-table .html-unavailable > a:first-child { color: #666; }
      @media (max-width: 960px) {
        .layout-with-sidebar { grid-template-columns: 1fr; }
        .sidebar-panel { position: static; }
        main { margin: 24px auto; }
      }
    </style>
  </head>
  <body>
    <header>
      <%= render "shared/navbar" %>
    </header>
    <% if content_for?(:left_content) %>
      <div class="layout-with-sidebar">
        <aside class="sidebar-panel">
          <%= yield :left_content %>
        </aside>
        <main class="main-panel">
          <%= render "shared/flash_messages" %>
          <%= yield %>
        </main>
      </div>
    <% else %>
      <main>
        <%= render "shared/flash_messages" %>
        <%= yield %>
      </main>
    <% end %>
  </body>
</html>
