- page_title "#{@document.title} / #{@document_file.file_name}"

p.muted
  = link_to @project.name, project_path(@project)
  |  /
  = link_to @document.title, project_document_path(@project, @document.slug)
  |  /
  = link_to @document_version.version_label, document_version_path(@document_version)

.document-viewer
  .document-viewer__header
    div
      h1.document-viewer__title = @document_file.file_name
      p.document-viewer__meta
        = @document_file.effective_content_type
        |  / 
        = number_to_human_size(@document_file.file_size)
    p.actions
      = link_to "画像を別タブで開く", document_file_path(@document_file, disposition: "inline", embedded: true), class: "button secondary", target: "_blank", rel: "noopener"
      = link_to "ダウンロード", document_file_path(@document_file, disposition: "download"), class: "button secondary"

  .card data-image-preview-tools="true" data-image-preview-storage-key=@document_file.public_id
    .markdown-workspace__header
      div
        h2 Image preview
        p.muted ブラウザで表示可能な画像ファイルを inline preview します。
      .actions
        span.muted data-image-preview-status="true"
        button.button.secondary type="button" data-image-preview-zoom-out="true" 縮小
        button.button.secondary type="button" data-image-preview-zoom-reset="true" 100%
        button.button.secondary type="button" data-image-preview-zoom-in="true" 拡大
        button.button.secondary type="button" data-image-preview-fit-toggle="true" aria-pressed="true" 画面に合わせる
    .rendered-table-diff-scroll
      = image_tag document_file_path(@document_file, disposition: "inline", embedded: true), alt: @document_file.file_name, data: { image_preview_image: true }, style: "display: block; max-width: 100%; height: auto; margin: 0 auto;"

javascript:
  (() => {
    document.querySelectorAll("[data-image-preview-tools]").forEach((container) => {
      if (container.dataset.imagePreviewToolsReady === "true") return
      container.dataset.imagePreviewToolsReady = "true"

      const image = container.querySelector("[data-image-preview-image]")
      const fitToggle = container.querySelector("[data-image-preview-fit-toggle]")
      const zoomOutButton = container.querySelector("[data-image-preview-zoom-out]")
      const zoomResetButton = container.querySelector("[data-image-preview-zoom-reset]")
      const zoomInButton = container.querySelector("[data-image-preview-zoom-in]")
      const status = container.querySelector("[data-image-preview-status]")
      if (!image || !fitToggle || !zoomOutButton || !zoomResetButton || !zoomInButton || !status) return

      const storageKey = `docsPortal.imagePreview:${container.dataset.imagePreviewStorageKey || window.location.pathname}`
      const readState = () => {
        try {
          return { fit: true, zoom: 1, ...JSON.parse(window.localStorage.getItem(storageKey) || "{}") }
        } catch (_error) {
          return { fit: true, zoom: 1 }
        }
      }
      const writeState = (state) => window.localStorage.setItem(storageKey, JSON.stringify(state))
      const clampZoom = (value) => Math.min(4, Math.max(0.25, value))
      let state = readState()

      const applyState = () => {
        const zoom = clampZoom(Number(state.zoom) || 1)
        state.zoom = zoom
        if (state.fit) {
          image.style.maxWidth = "100%"
          image.style.width = "auto"
          image.style.margin = "0 auto"
        } else {
          image.style.maxWidth = "none"
          image.style.width = `${Math.round(zoom * 100)}%`
          image.style.margin = "0"
        }
        image.style.height = "auto"
        fitToggle.setAttribute("aria-pressed", String(state.fit))
        fitToggle.textContent = state.fit ? "画面に合わせる" : "倍率表示中"
        status.textContent = state.fit ? "画面幅に合わせて表示しています" : `${Math.round(zoom * 100)}%で表示しています`
        writeState(state)
      }

      const setZoom = (zoom) => {
        state = { fit: false, zoom: clampZoom(zoom) }
        applyState()
      }

      fitToggle.addEventListener("click", () => {
        state = { ...state, fit: !state.fit }
        applyState()
      })
      zoomOutButton.addEventListener("click", () => setZoom((Number(state.zoom) || 1) - 0.25))
      zoomResetButton.addEventListener("click", () => setZoom(1))
      zoomInButton.addEventListener("click", () => setZoom((Number(state.zoom) || 1) + 0.25))

      applyState()
    })
  })()
