- current_files = @version.document_files.order(:sort_order, :file_name).to_a
- previous_files = @compare_version&.document_files&.order(:sort_order, :file_name)&.to_a || []
- current_by_path = current_files.index_by(&:tree_path)
- previous_by_path = previous_files.index_by(&:tree_path)
- review_paths = (current_by_path.keys + previous_by_path.keys).compact.uniq.sort

- if review_paths.any?
  .card.side-by-side-file-review#side-by-side-file-review
    .markdown-workspace__header
      div
        h2 左右確認ビュー
        p.muted PDFやOfficeなどテキストdiffが取りにくいファイルは、前版と今回版を左右に並べて見比べられます。
      .actions
        - if @compare_version
          = link_to "比較対象版を開く", document_version_path(@compare_version), class: "button secondary"
    - review_paths.each do |path|
      - current_file = current_by_path[path]
      - previous_file = previous_by_path[path]
      details.side-by-side-file-review__item open=(current_file.present? && previous_file.present?)
        summary
          strong = path
          - if current_file && previous_file
            span.badge changed
          - elsif current_file
            span.badge added
          - else
            span.badge removed
        .side-by-side-file-review__grid
          .side-by-side-file-review__pane
            h3 比較対象
            - if previous_file
              p.muted = previous_file.effective_content_type
              - if previous_file.embeddable_viewer_file?
                iframe.side-by-side-file-review__frame src=document_file_path(previous_file, disposition: "inline", embedded: "1") title="#{path} previous"
              - else
                p.muted このファイルはブラウザ内プレビューに対応していません。
                = link_to "ダウンロード", document_file_path(previous_file), class: "button secondary"
            - else
              p.muted 比較対象版にはありません。
          .side-by-side-file-review__pane
            h3 表示中
            - if current_file
              p.muted = current_file.effective_content_type
              - if current_file.embeddable_viewer_file?
                iframe.side-by-side-file-review__frame src=document_file_path(current_file, disposition: "inline", embedded: "1") title="#{path} current"
              - else
                p.muted このファイルはブラウザ内プレビューに対応していません。
                = link_to "ダウンロード", document_file_path(current_file), class: "button secondary"
            - else
              p.muted 表示中の版にはありません。
