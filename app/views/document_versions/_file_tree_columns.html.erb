<td>
  <% if item.directory? %>
    <strong><%= item.label %></strong>
  <% else %>
    <%= item.label %>
  <% end %>
</td>
<td>
  <% if item.file? %>
    <% viewer_plan = document_file_viewer_plan(item.document_file) %>
    <span><%= viewer_plan.label %></span>
    <br>
    <span class="muted"><%= item.document_file.effective_content_type %></span>
  <% else %>
    <span class="muted">-</span>
  <% end %>
</td>
<td>
  <% if item.file? %>
    <%= number_to_human_size(item.document_file.file_size) %>
  <% else %>
    <span class="muted">-</span>
  <% end %>
</td>
<td class="actions">
  <% if item.file? %>
    <% file = item.document_file %>
    <% viewer_plan = document_file_viewer_plan(file) %>
    <% if viewer_plan.downloadable? %>
      <% if viewer_plan.inline_disposition? %>
        <%= link_to "プレビュー", document_file_path(file, disposition: "inline") %>
      <% elsif viewer_plan.reason.present? %>
        <span class="muted"><%= viewer_plan.reason %></span>
      <% end %>
      <%= link_to "ダウンロード", document_file_path(file, disposition: "download") %>
    <% else %>
      <span class="muted">権限なし</span>
      <% if viewer_plan.reason.present? %>
        <span class="muted"><%= viewer_plan.reason %></span>
      <% end %>
      <%= button_to "申請", access_requests_path, params: { requestable_type: "DocumentFile", requestable_public_id: file.public_id, requested_access_level: "download" }, class: "button secondary" %>
    <% end %>
  <% else %>
    <span class="muted">-</span>
  <% end %>
</td>
