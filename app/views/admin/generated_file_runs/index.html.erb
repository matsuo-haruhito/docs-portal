<%
  detail_path_params = { return_to: request.fullpath }
  status_filter_params = request.query_parameters.except(:page, :per_page).compact_blank
%>

<div class="space-y-6">
  <div class="flex items-start justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold">生成ファイル実行履歴</h1>
      <p class="text-sm text-gray-600">ファイルCRUDイベントから起動された生成Jobの履歴です。</p>
    </div>
    <div class="text-right">
      <%= button_to "失敗分を一括再実行", retry_failed_admin_generated_file_runs_path(@filters.compact_blank), method: :post, class: "rounded bg-blue-600 px-3 py-2 text-sm text-white" %>
      <p class="mt-1 text-xs text-gray-500">一括再実行は古い失敗分から最大100件です。</p>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-3 md:grid-cols-4">
    <% GeneratedFileRun.statuses.keys.each do |status| %>
      <%= link_to admin_generated_file_runs_path(status_filter_params.merge("status" => status)), class: "rounded-lg border bg-white p-4" do %>
        <div class="text-xs font-semibold uppercase text-gray-500"><%= generated_file_run_status_label(status) %></div>
        <div class="mt-1 text-2xl font-bold"><%= @status_counts.fetch(status, 0) %></div>
      <% end %>
    <% end %>
  </div>

  <%= form_with url: admin_generated_file_runs_path, method: :get, local: true, class: "rounded-lg border bg-white p-4" do |form| %>
    <div class="grid grid-cols-1 gap-3 md:grid-cols-4">
      <div>
        <%= form.label :status, "状態", class: "block text-sm font-semibold" %>
        <%= form.select :status, options_for_select([["すべて", ""]] + GeneratedFileRun.statuses.keys.map { [generated_file_run_status_label(_1), _1] }, @filters[:status]), {}, class: "mt-1 w-full rounded border px-2 py-1" %>
      </div>
      <div>
        <%= form.label :job_id, "ジョブID", class: "block text-sm font-semibold" %>
        <%= form.text_field :job_id, value: @filters[:job_id], class: "mt-1 w-full rounded border px-2 py-1" %>
      </div>
      <div>
        <%= form.label :generator, "ジェネレーター", class: "block text-sm font-semibold" %>
        <%= form.text_field :generator, value: @filters[:generator], class: "mt-1 w-full rounded border px-2 py-1" %>
      </div>
      <div>
        <%= form.label :output_writer, "出力先", class: "block text-sm font-semibold" %>
        <%= form.text_field :output_writer, value: @filters[:output_writer], class: "mt-1 w-full rounded border px-2 py-1" %>
      </div>
      <div>
        <%= form.label :event_source, "イベント発生元", class: "block text-sm font-semibold" %>
        <%= form.text_field :event_source, value: @filters[:event_source], class: "mt-1 w-full rounded border px-2 py-1" %>
      </div>
      <div>
        <%= form.label :created_from, "作成日(開始)", class: "block text-sm font-semibold" %>
        <%= form.text_field :created_from, value: @filters[:created_from], placeholder: "YYYY-MM-DD", class: "mt-1 w-full rounded border px-2 py-1" %>
      </div>
      <div>
        <%= form.label :created_to, "作成日(終了)", class: "block text-sm font-semibold" %>
        <%= form.text_field :created_to, value: @filters[:created_to], placeholder: "YYYY-MM-DD", class: "mt-1 w-full rounded border px-2 py-1" %>
      </div>
      <div class="flex items-end gap-2">
        <%= form.submit "絞り込み", class: "rounded bg-blue-600 px-3 py-2 text-sm text-white" %>
        <%= link_to "クリア", admin_generated_file_runs_path, class: "rounded border px-3 py-2 text-sm" %>
      </div>
    </div>
  <% end %>

  <%= render "admin/shared/pagination",
    total_count: @total_count,
    page: @page,
    total_pages: @total_pages,
    path: ->(target_page) { admin_generated_file_runs_path(request.query_parameters.merge(page: target_page, per_page: @per_page)) } %>

  <div class="overflow-x-auto rounded-lg border bg-white">
    <table class="min-w-full divide-y divide-gray-200 text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-3 text-left font-semibold">実行ID</th>
          <th class="px-4 py-3 text-left font-semibold">状態</th>
          <th class="px-4 py-3 text-left font-semibold">ジョブ</th>
          <th class="px-4 py-3 text-left font-semibold">ジェネレーター</th>
          <th class="px-4 py-3 text-left font-semibold">出力先</th>
          <th class="px-4 py-3 text-left font-semibold">イベント発生元</th>
          <th class="px-4 py-3 text-left font-semibold">開始</th>
          <th class="px-4 py-3 text-left font-semibold">終了</th>
          <th class="px-4 py-3 text-left font-semibold">操作</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% if @generated_file_runs.any? %>
          <% @generated_file_runs.each do |run| %>
            <tr>
              <td class="px-4 py-3 font-mono">
                <%= link_to run.public_id, admin_generated_file_run_path(run.public_id, detail_path_params), class: "text-blue-600 underline" %>
              </td>
              <td class="px-4 py-3"><%= generated_file_run_status_label(run.status) %></td>
              <td class="px-4 py-3 font-mono"><%= run.job_id %></td>
              <td class="px-4 py-3 font-mono"><%= run.generator.presence || "-" %></td>
              <td class="px-4 py-3 font-mono"><%= run.output_writer.presence || "-" %></td>
              <td class="px-4 py-3"><%= generated_file_source_label(run.event_source) %></td>
              <td class="px-4 py-3"><%= l(run.started_at, format: :long) if run.started_at %></td>
              <td class="px-4 py-3"><%= l(run.finished_at, format: :long) if run.finished_at %></td>
              <td class="px-4 py-3">
                <div class="flex gap-2">
                  <%= link_to "詳細", admin_generated_file_run_path(run.public_id, detail_path_params), class: "rounded border px-2 py-1 text-xs" %>
                  <%= button_to "再実行", retry_run_admin_generated_file_run_path(run.public_id, detail_path_params), method: :post, class: "rounded bg-blue-600 px-2 py-1 text-xs text-white" %>
                </div>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="9" class="px-4 py-8 text-center text-gray-500">条件に一致する生成ファイル実行履歴はありません。</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
