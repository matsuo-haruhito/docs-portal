<%
  detail_path_params = { return_to: request.fullpath }
  status_filter_params = request.query_parameters.except(:page, :per_page).compact_blank
  has_active_filters = @filters.compact_blank.any?
  bulk_retry_target_count = @bulk_retry_target_count.to_i
  bulk_retry_available = bulk_retry_target_count.positive?
  bulk_retry_button_classes = bulk_retry_available ? "rounded bg-blue-600 px-3 py-2 text-sm text-white" : "rounded bg-gray-300 px-3 py-2 text-sm text-gray-600 cursor-not-allowed"
  bulk_retry_confirm_message = "現在の条件に一致する失敗履歴 #{bulk_retry_target_count} 件のうち、古い順に最大100件を一括再実行します。現在の条件を確認してから実行してください。実行しますか？"
  bulk_retry_scope_copy = generated_file_run_bulk_retry_scope_copy(@filters)
  bulk_retry_filter_summary = generated_file_run_bulk_retry_filter_summary(@filters)
  table_key = :admin_generated_file_runs
  table_columns = generated_file_run_table_columns
  table_settings = rails_table_preference_settings(table_key: table_key)
%>

<div class="space-y-6">
  <div class="flex items-start justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold">生成ファイル実行履歴</h1>
      <p class="text-sm text-gray-600">ファイルCRUDイベントから起動された生成Jobの履歴です。</p>
    </div>
    <div class="text-right">
      <%= button_to "失敗分を一括再実行", retry_failed_admin_generated_file_runs_path(@filters.compact_blank), method: :post, disabled: !bulk_retry_available, class: bulk_retry_button_classes, form: { data: { turbo_confirm: bulk_retry_confirm_message } } %>
      <p class="mt-1 text-xs text-gray-500">現在の条件で再実行対象: <strong><%= bulk_retry_target_count %> 件</strong></p>
      <div class="mt-2 rounded border border-blue-100 bg-blue-50 px-3 py-2 text-left text-xs text-blue-900">
        <p class="font-semibold">一括再実行の対象条件</p>
        <p class="mt-1"><%= bulk_retry_scope_copy %></p>
        <% if bulk_retry_filter_summary.any? %>
          <ul class="mt-1 list-disc pl-4">
            <% bulk_retry_filter_summary.each do |summary_item| %>
              <li><%= summary_item %></li>
            <% end %>
          </ul>
        <% end %>
      </div>
      <% if bulk_retry_available %>
        <p class="mt-1 text-xs text-gray-500">このボタンは現在の絞り込み条件に一致する失敗履歴だけを対象にします。古い順に最大100件です。</p>
      <% else %>
        <p class="mt-1 text-xs text-gray-500">対象がないため一括再実行できません。</p>
      <% end %>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-3 md:grid-cols-4">
    <% GeneratedFileRun.statuses.keys.each do |status| %>
      <%= link_to admin_generated_file_runs_path(status_filter_params.merge("status" => status)), class: "rounded-lg border bg-white p-4" do %>
        <div class="text-xs font-semibold uppercase text-gray-500"><%= generated_file_run_status_label(status) %></div>
        <div class="mt-1 text-2xl font-bold"><%= @status_counts.fetch(status, 0) %></div>
      <% end %>
    <% end %>
  </div>

  <% if @filter_warnings.present? %>
    <div class="rounded border border-amber-300 bg-amber-50 p-3 text-sm text-amber-900">
      <p class="font-semibold">日時フィルタを確認してください。</p>
      <ul class="mt-1 list-disc pl-5">
        <% @filter_warnings.each do |warning| %>
          <li><%= warning %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with url: admin_generated_file_runs_path, method: :get, local: true, class: "rounded-lg border bg-white p-4" do |form| %>
    <div class="grid grid-cols-1 gap-3 md:grid-cols-4">
      <div class="md:col-span-2">
        <%= form.label :q, "実行ID / パス / エラー / メタデータ", class: "block text-sm font-semibold" %>
        <%= form.text_field :q, value: @filters[:q], placeholder: "gfr... / docs/source.yml / timeout / metadata断片", maxlength: Admin::GeneratedFileRunsController::QUERY_MAX_LENGTH, class: "mt-1 w-full rounded border px-2 py-1" %>
        <p class="mt-1 text-xs text-gray-500">検索語は最大<%= Admin::GeneratedFileRunsController::QUERY_MAX_LENGTH %>文字です。入力パス・変更ファイル・生成パス・エラー文・補助メタデータを検索します。長いメタデータJSONやエラー文は、特徴的な短い断片で探してください。</p>
      </div>
      <div>
        <%= form.label :status, "状態", class: "block text-sm font-semibold" %>
        <%= form.select :status, options_for_select([["すべて", ""]] + GeneratedFileRun.statuses.keys.map { [generated_file_run_status_label(_1), _1] }, @filters[:status]), {}, class: "mt-1 w-full rounded border px-2 py-1" %>
      </div>
      <div>
        <%= form.label :job_id, "ジョブID", class: "block text-sm font-semibold" %>
        <%= form.text_field :job_id, value: @filters[:job_id], class: "mt-1 w-full rounded border px-2 py-1" %>
      </div>
      <div>
        <%= form.label :generator, "ジェネレーター", class: "block text-sm font-semibold" %>
        <%= form.text_field :generator, value: @filters[:generator], class: "mt-1 w-full rounded border px-2 py-1" %>
      </div>
      <div>
        <%= form.label :output_writer, "出力先", class: "block text-sm font-semibold" %>
        <%= form.text_field :output_writer, value: @filters[:output_writer], class: "mt-1 w-full rounded border px-2 py-1" %>
      </div>
      <div>
        <%= form.label :event_source, "イベント発生元", class: "block text-sm font-semibold" %>
        <%= form.text_field :event_source, value: @filters[:event_source], class: "mt-1 w-full rounded border px-2 py-1" %>
      </div>
      <div>
        <%= form.label :created_from, "作成日(開始)", class: "block text-sm font-semibold" %>
        <%= form.text_field :created_from, value: @filters[:created_from], placeholder: "YYYY-MM-DD", class: "mt-1 w-full rounded border px-2 py-1" %>
        <p class="mt-1 text-xs text-gray-500">日付だけ指定すると、その日の00:00以降を含みます。</p>
      </div>
      <div>
        <%= form.label :created_to, "作成日(終了)", class: "block text-sm font-semibold" %>
        <%= form.text_field :created_to, value: @filters[:created_to], placeholder: "YYYY-MM-DD", class: "mt-1 w-full rounded border px-2 py-1" %>
        <p class="mt-1 text-xs text-gray-500">日付だけ指定すると、その日の23:59までを含みます。</p>
      </div>
      <div class="flex items-end gap-2">
        <%= form.submit "絞り込み", class: "rounded bg-blue-600 px-3 py-2 text-sm text-white" %>
        <% if has_active_filters %>
          <%= link_to "絞り込みを解除", admin_generated_file_runs_path, class: "rounded border px-3 py-2 text-sm" %>
        <% end %>
      </div>
    </div>
  <% end %>

  <%= render "admin/shared/pagination",
    total_count: @total_count,
    page: @page,
    total_pages: @total_pages,
    path: ->(target_page) { admin_generated_file_runs_path(request.query_parameters.merge(page: target_page, per_page: @per_page)) } %>

  <% if @generated_file_runs.any? %>
    <div class="rounded-lg border bg-white p-4">
      <%= table_preferences_editor(table_key: table_key, settings: table_settings, columns: table_columns, title: "生成ファイル実行履歴一覧の表示設定") %>
    </div>
  <% end %>

  <div class="overflow-x-auto rounded-lg border bg-white">
    <%= table_preferences_table_tag(table_key: table_key, settings: table_settings, columns: table_columns) do %>
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-3 text-left font-semibold" data-rails-table-preferences-column-key="public_id">実行ID</th>
          <th class="px-4 py-3 text-left font-semibold" data-rails-table-preferences-column-key="status">状態</th>
          <th class="px-4 py-3 text-left font-semibold" data-rails-table-preferences-column-key="job_id">ジョブ</th>
          <th class="px-4 py-3 text-left font-semibold" data-rails-table-preferences-column-key="generator">ジェネレーター</th>
          <th class="px-4 py-3 text-left font-semibold" data-rails-table-preferences-column-key="output_writer">出力先</th>
          <th class="px-4 py-3 text-left font-semibold" data-rails-table-preferences-column-key="event_source">イベント発生元</th>
          <th class="px-4 py-3 text-left font-semibold" data-rails-table-preferences-column-key="started_at">開始</th>
          <th class="px-4 py-3 text-left font-semibold" data-rails-table-preferences-column-key="finished_at">終了</th>
          <th class="px-4 py-3 text-left font-semibold" data-rails-table-preferences-column-key="actions">操作</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% if @generated_file_runs.any? %>
          <% @generated_file_runs.each do |run| %>
            <tr>
              <td class="px-4 py-3 font-mono" data-rails-table-preferences-column-key="public_id">
                <%= link_to run.public_id, admin_generated_file_run_path(run.public_id, detail_path_params), class: "text-blue-600 underline" %>
              </td>
              <td class="px-4 py-3" data-rails-table-preferences-column-key="status"><%= generated_file_run_status_label(run.status) %></td>
              <td class="px-4 py-3 font-mono" data-rails-table-preferences-column-key="job_id"><%= run.job_id %></td>
              <td class="px-4 py-3 font-mono" data-rails-table-preferences-column-key="generator"><%= run.generator.presence || "-" %></td>
              <td class="px-4 py-3 font-mono" data-rails-table-preferences-column-key="output_writer"><%= run.output_writer.presence || "-" %></td>
              <td class="px-4 py-3" data-rails-table-preferences-column-key="event_source"><%= generated_file_source_label(run.event_source) %></td>
              <td class="px-4 py-3" data-rails-table-preferences-column-key="started_at"><%= l(run.started_at, format: :long) if run.started_at %></td>
              <td class="px-4 py-3" data-rails-table-preferences-column-key="finished_at"><%= l(run.finished_at, format: :long) if run.finished_at %></td>
              <td class="px-4 py-3" data-rails-table-preferences-column-key="actions">
                <div class="flex gap-2">
                  <%= link_to "詳細", admin_generated_file_run_path(run.public_id, detail_path_params), class: "rounded border px-2 py-1 text-xs" %>
                  <%= button_to "この行を再実行", retry_run_admin_generated_file_run_path(run.public_id, detail_path_params), method: :post, class: "rounded bg-blue-600 px-2 py-1 text-xs text-white" %>
                </div>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="<%= table_columns.size %>" class="px-4 py-8 text-center text-gray-500">
              <% if has_active_filters %>
                <div class="generated-file-run-filter-empty-state space-y-2">
                  <p>条件に一致する生成ファイル実行履歴はありません。</p>
                  <p class="text-sm">これは表示フィルタの結果です。条件を見直すか、すべての生成ファイル実行履歴を表示してください。</p>
                  <p class="actions mt-3"><%= link_to "すべての生成ファイル実行履歴を見る", admin_generated_file_runs_path, class: "rounded border px-3 py-2 text-sm" %></p>
                </div>
              <% else %>
                生成ファイル実行履歴はまだありません。
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    <% end %>
  </div>
</div>