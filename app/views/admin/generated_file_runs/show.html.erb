<% return_to_path = @return_to_path || admin_generated_file_runs_path %>

<div class="space-y-6">
  <div class="flex items-start justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold">生成ファイル実行履歴</h1>
      <p class="font-mono text-sm text-gray-600"><%= @generated_file_run.public_id %></p>
    </div>
    <div class="flex max-w-md flex-col items-end gap-2 text-right">
      <div class="flex gap-2">
        <%= link_to "一覧へ戻る", return_to_path, class: "rounded border px-3 py-2 text-sm" %>
        <%= button_to "この実行を再実行", retry_run_admin_generated_file_run_path(@generated_file_run.public_id, return_to: return_to_path), method: :post, class: "rounded bg-blue-600 px-3 py-2 text-sm text-white", title: "#{@generated_file_run.public_id} を再実行キューに投入", aria: {label: "#{@generated_file_run.public_id} を再実行キューに投入"} %>
      </div>
      <p class="text-xs text-gray-500">この実行1件だけを再実行キューへ投入します。元の実行履歴は診断用に残り、新しい実行IDで再実行後の結果を確認します。</p>
    </div>
  </div>

  <div class="rounded-lg border bg-white p-4">
    <h2 class="mb-3 text-lg font-semibold">概要</h2>
    <dl class="grid grid-cols-1 gap-3 text-sm md:grid-cols-2">
      <div><dt class="font-semibold">状態</dt><dd><%= generated_file_run_status_label(@generated_file_run.status) %></dd></div>
      <div><dt class="font-semibold">ジョブID</dt><dd class="font-mono"><%= @generated_file_run.job_id %></dd></div>
      <div><dt class="font-semibold">ジェネレータ</dt><dd class="font-mono"><%= @generated_file_run.generator.presence || "-" %></dd></div>
      <div><dt class="font-semibold">出力ライター</dt><dd class="font-mono"><%= @generated_file_run.output_writer.presence || "-" %></dd></div>
      <div>
        <dt class="font-semibold">発生元</dt>
        <dd class="flex flex-wrap items-center gap-2">
          <span><%= generated_file_source_label(@generated_file_run.event_source) %></span>
          <% if (badge_label = generated_file_source_badge_label(@generated_file_run.event_source)) %>
            <span class="badge"><%= badge_label %></span>
          <% end %>
        </dd>
      </div>
      <div><dt class="font-semibold">開始</dt><dd><%= l(@generated_file_run.started_at, format: :long) if @generated_file_run.started_at %></dd></div>
      <div><dt class="font-semibold">完了</dt><dd><%= l(@generated_file_run.finished_at, format: :long) if @generated_file_run.finished_at %></dd></div>
    </dl>
  </div>

  <% if @retry_evidence_visible %>
    <div class="rounded-lg border bg-white p-4">
      <h2 class="mb-3 text-lg font-semibold">再実行履歴</h2>
      <dl class="grid grid-cols-1 gap-3 text-sm md:grid-cols-2">
        <div><dt class="font-semibold">種別</dt> <dd><%= generated_file_run_retry_kind_label(@generated_file_run) %></dd></div>
        <div>
          <dt class="font-semibold">再実行元</dt>
          <dd class="font-mono">
            <% if @retry_of_generated_file_run_public_id.present? %>
              <% if @retry_of_generated_file_run %>
                <%= link_to @retry_of_generated_file_run_public_id, admin_generated_file_run_path(@retry_of_generated_file_run_public_id, return_to: return_to_path), class: "text-blue-600 underline" %>
              <% else %>
                <%= @retry_of_generated_file_run_public_id %>
              <% end %>
            <% else %>
              -
            <% end %>
          </dd>
        </div>
        <div><dt class="font-semibold">再実行依頼者</dt><dd><%= generated_file_run_retry_requester_label(@retry_requested_by_user_id, @retry_requested_by_user) %></dd></div>
        <div><dt class="font-semibold">再実行依頼時刻</dt><dd><%= @generated_file_run.metadata&.dig("retry_requested_at").presence || "-" %></dd></div>
        <div><dt class="font-semibold">確認先</dt><dd class="font-mono"><%= @generated_file_run.public_id %></dd></div>
        <div><dt class="font-semibold">運用runbook</dt><dd class="font-mono">docs/生成ファイル再試行と定期ジョブ管理runbook.md</dd></div>
      </dl>
      <p class="mt-3 text-xs text-gray-600">既存の再実行 metadata から読める範囲だけを表示します。raw command、長い log、credential は表示対象にしません。</p>
    </div>
  <% end %>

  <% if @related_generated_file_event_public_ids.any? || @retry_child_runs.any? %>
    <div class="rounded-lg border bg-white p-4">
      <h2 class="mb-3 text-lg font-semibold">関連情報</h2>

      <% if @related_generated_file_event_public_ids.any? %>
        <div class="mb-4">
          <h3 class="mb-2 text-sm font-semibold">関連イベント</h3>
          <ul class="space-y-1 text-sm">
            <% @related_generated_file_event_public_ids.each do |public_id| %>
              <% event = @related_generated_file_events_by_public_id[public_id] %>
              <li>
                <% if event %>
                  <%= link_to public_id, admin_generated_file_event_path(public_id, return_to: return_to_path), class: "font-mono text-blue-600 underline" %>
                  <span class="muted"><%= generated_file_event_status_label(event.status) %></span>
                <% else %>
                  <span class="font-mono"><%= public_id %></span>
                  <span class="muted">（未検出）</span>
                <% end %>
              </li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <% if @retry_child_runs.any? %>
        <div>
          <h3 class="mb-2 text-sm font-semibold">この実行から派生した再実行</h3>
          <ul class="space-y-1 text-sm">
            <% @retry_child_runs.each do |run| %>
              <li>
                <%= link_to run.public_id, admin_generated_file_run_path(run.public_id, return_to: return_to_path), class: "font-mono text-blue-600 underline" %>
                <span class="muted"><%= generated_file_run_status_label(run.status) %></span>
                <% if run.event_source == "generated_file_run_retry" %>
                  <span class="badge">再実行</span>
                <% elsif run.event_source == "generated_file_run_bulk_retry" %>
                  <span class="badge">一括再実行</span>
                <% end %>
              </li>
            <% end %>
          </ul>
        </div>
      <% end %>
    </div>
  <% end %>

  <% if @generated_file_run.error_message.present? %>
    <div class="rounded-lg border border-red-200 bg-red-50 p-4">
      <h2 class="mb-2 text-lg font-semibold text-red-700">エラー</h2>
      <p class="mb-2 text-xs text-gray-600">エラーは診断用プレビューです。長い本文は省略され、token / secret / private path は伏せています。</p>
      <pre class="whitespace-pre-wrap text-sm"><%= generated_file_run_diagnostic_preview(@generated_file_run.error_message) %></pre>
    </div>
  <% end %>

  <div class="grid grid-cols-1 gap-4 lg:grid-cols-2">
    <div class="rounded-lg border bg-white p-4">
      <h2 class="mb-2 text-lg font-semibold">入力パス</h2>
      <p class="mb-2 text-xs text-gray-600">入力パスはジョブ診断用の配列表示です。生成ジョブの入力を再確認する手がかりとして扱います。</p>
      <pre class="whitespace-pre-wrap text-sm"><%= JSON.pretty_generate(@generated_file_run.source_paths || []) %></pre>
    </div>
    <div class="rounded-lg border bg-white p-4">
      <h2 class="mb-2 text-lg font-semibold">変更ファイル</h2>
      <p class="mb-2 text-xs text-gray-600">変更ファイルはジョブ診断用の配列表示です。生成前後の差分を再確認する手がかりとして扱います。</p>
      <pre class="whitespace-pre-wrap text-sm"><%= JSON.pretty_generate(@generated_file_run.changed_files || []) %></pre>
    </div>
    <div class="rounded-lg border bg-white p-4">
      <h2 class="mb-2 text-lg font-semibold">生成パス</h2>
      <p class="mb-2 text-xs text-gray-600">生成パスはジョブ診断用の配列表示です。出力先の確認入口として扱います。</p>
      <pre class="whitespace-pre-wrap text-sm"><%= JSON.pretty_generate(@generated_file_run.generated_paths || []) %></pre>
    </div>
    <div class="rounded-lg border bg-white p-4">
      <h2 class="mb-2 text-lg font-semibold">メタデータ</h2>
      <p class="mb-2 text-xs text-gray-600">メタデータは診断用プレビューです。token / secret / private path は表示前に伏せています。</p>
      <pre class="whitespace-pre-wrap text-sm"><%= generated_file_run_metadata_preview(@generated_file_run.metadata) %></pre>
    </div>
  </div>
</div>
