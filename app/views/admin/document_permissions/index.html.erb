<% page_title "文書権限" %>
<h1>文書権限</h1>
<%= render "admin/nav" %>

<div class="card">
  <h2>新規登録</h2>
  <%= render "form", document_permission: @document_permission %>
</div>

<%= table_tag do %>
  <thead>
    <tr>
      <th>文書</th>
      <th>会社</th>
      <th>ユーザー</th>
      <th>権限</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @document_permissions.each do |permission| %>
      <tr>
        <td><%= permission.document.title %></td>
        <td><%= permission.company&.name || "-" %></td>
        <td><%= permission.user&.email_address || "-" %></td>
        <td><span class="badge"><%= permission.access_level %></span></td>
        <td class="actions">
          <%= edit_link_to "編集", edit_admin_document_permission_path(permission) %>
          <%= delete_link_to "削除", admin_document_permission_path(permission) %>
        </td>
      </tr>
    <% end %>
  </tbody>
<% end %>
