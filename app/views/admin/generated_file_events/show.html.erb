<div class="space-y-6">
  <div class="flex items-start justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold">生成ファイルイベント</h1>
      <p class="font-mono text-sm text-gray-600"><%= @generated_file_event.public_id %></p>
    </div>
    <div class="flex gap-2">
      <%= link_to "一覧へ戻る", admin_generated_file_events_path, class: "rounded border px-3 py-2 text-sm" %>
      <%= button_to "再dispatch", retry_dispatch_admin_generated_file_event_path(@generated_file_event.public_id), method: :post, class: "rounded bg-blue-600 px-3 py-2 text-sm text-white" %>
    </div>
  </div>

  <div class="rounded-lg border bg-white p-4">
    <h2 class="mb-3 text-lg font-semibold">概要</h2>
    <dl class="grid grid-cols-1 gap-3 text-sm md:grid-cols-2">
      <div><dt class="font-semibold">Status</dt><dd><%= @generated_file_event.status %></dd></div>
      <div><dt class="font-semibold">Event Key</dt><dd class="font-mono"><%= @generated_file_event.event_key %></dd></div>
      <div><dt class="font-semibold">Path</dt><dd class="font-mono"><%= @generated_file_event.path %></dd><dd class="text-xs text-gray-500">/ 区切りで保存されます。</dd></div>
      <div><dt class="font-semibold">Operation</dt><dd><%= @generated_file_event.operation %></dd></div>
      <div><dt class="font-semibold">Event Source</dt><dd><%= @generated_file_event.event_source.presence || "-" %></dd></div>
      <div><dt class="font-semibold">Occurrences</dt><dd><%= @generated_file_event.occurrences_count %></dd></div>
      <div><dt class="font-semibold">Scheduled</dt><dd><%= l(@generated_file_event.scheduled_at, format: :long) if @generated_file_event.scheduled_at %></dd></div>
      <div><dt class="font-semibold">Last Seen</dt><dd><%= l(@generated_file_event.last_seen_at, format: :long) if @generated_file_event.last_seen_at %></dd></div>
      <div><dt class="font-semibold">Processed</dt><dd><%= l(@generated_file_event.processed_at, format: :long) if @generated_file_event.processed_at %></dd></div>
    </dl>
  </div>

  <% if @generated_file_event.error_message.present? %>
    <div class="rounded-lg border border-red-200 bg-red-50 p-4">
      <h2 class="mb-2 text-lg font-semibold text-red-700">Error</h2>
      <pre class="whitespace-pre-wrap text-sm"><%= @generated_file_event.error_message %></pre>
    </div>
  <% end %>

  <div class="rounded-lg border bg-white p-4">
    <h2 class="mb-2 text-lg font-semibold">Metadata</h2>
    <pre class="whitespace-pre-wrap text-sm"><%= JSON.pretty_generate(@generated_file_event.metadata || {}) %></pre>
  </div>
</div>
