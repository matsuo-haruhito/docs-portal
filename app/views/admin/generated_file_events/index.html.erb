<div class="space-y-6">
  <div class="flex items-start justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold">生成ファイルイベント</h1>
      <p class="text-sm text-gray-600">debounce / coalesce 用に蓄積されたファイル変更イベントです。</p>
    </div>
    <div class="flex items-center gap-2 text-sm">
      <%= button_to "失敗分を一括再dispatch", retry_failed_admin_generated_file_events_path, method: :post, class: "rounded bg-blue-600 px-3 py-2 text-sm text-white" %>
      <%= link_to "すべて", admin_generated_file_events_path, class: "rounded border px-3 py-2" %>
      <% GeneratedFileEvent.statuses.keys.each do |status| %>
        <%= link_to status, admin_generated_file_events_path(status: status), class: "rounded border px-3 py-2" %>
      <% end %>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-3 md:grid-cols-4">
    <% GeneratedFileEvent.statuses.keys.each do |status| %>
      <%= link_to admin_generated_file_events_path(status: status), class: "rounded-lg border bg-white p-4" do %>
        <div class="text-xs font-semibold uppercase text-gray-500"><%= status %></div>
        <div class="mt-1 text-2xl font-bold"><%= @status_counts.fetch(status, 0) %></div>
      <% end %>
    <% end %>
  </div>

  <%= form_with url: admin_generated_file_events_path, method: :get, local: true, class: "rounded-lg border bg-white p-4" do |form| %>
    <div class="grid grid-cols-1 gap-3 md:grid-cols-4">
      <div>
        <%= form.label :status, "Status", class: "block text-sm font-semibold" %>
        <%= form.select :status, options_for_select([["すべて", ""]] + GeneratedFileEvent.statuses.keys.map { [_1, _1] }, @filters[:status]), {}, class: "mt-1 w-full rounded border px-2 py-1" %>
      </div>
      <div>
        <%= form.label :operation, "Operation", class: "block text-sm font-semibold" %>
        <%= form.select :operation, options_for_select([["すべて", ""], ["create", "create"], ["update", "update"], ["delete", "delete"]], @filters[:operation]), {}, class: "mt-1 w-full rounded border px-2 py-1" %>
      </div>
      <div>
        <%= form.label :event_source, "Event Source", class: "block text-sm font-semibold" %>
        <%= form.text_field :event_source, value: @filters[:event_source], class: "mt-1 w-full rounded border px-2 py-1" %>
      </div>
      <div>
        <%= form.label :path, "Path contains", class: "block text-sm font-semibold" %>
        <%= form.text_field :path, value: @filters[:path], class: "mt-1 w-full rounded border px-2 py-1" %>
      </div>
      <div>
        <%= form.label :scheduled_from, "Scheduled From", class: "block text-sm font-semibold" %>
        <%= form.text_field :scheduled_from, value: @filters[:scheduled_from], placeholder: "YYYY-MM-DD", class: "mt-1 w-full rounded border px-2 py-1" %>
      </div>
      <div>
        <%= form.label :scheduled_to, "Scheduled To", class: "block text-sm font-semibold" %>
        <%= form.text_field :scheduled_to, value: @filters[:scheduled_to], placeholder: "YYYY-MM-DD", class: "mt-1 w-full rounded border px-2 py-1" %>
      </div>
      <div class="flex items-end gap-2">
        <%= form.submit "絞り込み", class: "rounded bg-blue-600 px-3 py-2 text-sm text-white" %>
        <%= link_to "クリア", admin_generated_file_events_path, class: "rounded border px-3 py-2 text-sm" %>
      </div>
    </div>
  <% end %>

  <%= render "admin/shared/pagination",
    total_count: @total_count,
    page: @page,
    total_pages: @total_pages,
    path: ->(target_page) { admin_generated_file_events_path(request.query_parameters.merge(page: target_page, per_page: @per_page)) } %>

  <div class="overflow-x-auto rounded-lg border bg-white">
    <table class="min-w-full divide-y divide-gray-200 text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-3 text-left font-semibold">Event ID</th>
          <th class="px-4 py-3 text-left font-semibold">Status</th>
          <th class="px-4 py-3 text-left font-semibold">Path</th>
          <th class="px-4 py-3 text-left font-semibold">Operation</th>
          <th class="px-4 py-3 text-left font-semibold">Source</th>
          <th class="px-4 py-3 text-left font-semibold">Count</th>
          <th class="px-4 py-3 text-left font-semibold">Scheduled</th>
          <th class="px-4 py-3 text-left font-semibold">Processed</th>
          <th class="px-4 py-3 text-left font-semibold">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @generated_file_events.each do |event| %>
          <tr>
            <td class="px-4 py-3 font-mono">
              <%= link_to event.public_id, admin_generated_file_event_path(event.public_id), class: "text-blue-600 underline" %>
            </td>
            <td class="px-4 py-3"><%= event.status %></td>
            <td class="px-4 py-3 font-mono"><%= event.path %></td>
            <td class="px-4 py-3"><%= event.operation %></td>
            <td class="px-4 py-3"><%= event.event_source.presence || "-" %></td>
            <td class="px-4 py-3"><%= event.occurrences_count %></td>
            <td class="px-4 py-3"><%= l(event.scheduled_at, format: :long) if event.scheduled_at %></td>
            <td class="px-4 py-3"><%= l(event.processed_at, format: :long) if event.processed_at %></td>
            <td class="px-4 py-3">
              <div class="flex gap-2">
                <%= link_to "詳細", admin_generated_file_event_path(event.public_id), class: "rounded border px-2 py-1 text-xs" %>
                <%= button_to "再dispatch", retry_dispatch_admin_generated_file_event_path(event.public_id), method: :post, class: "rounded bg-blue-600 px-2 py-1 text-xs text-white" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
