<%
  detail_path_params = { return_to: request.fullpath }
%>

<div class="space-y-6">
  <div class="flex items-start justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold">生成ファイルイベント</h1>
      <p class="text-sm text-gray-600">debounce / coalesce 用に蓄積されたファイル変更イベントです。</p>
    </div>
    <div class="space-y-2 text-right text-sm">
      <% bulk_retry_class = @filters[:status] == "failed" ? "rounded bg-red-600 px-3 py-2 text-sm font-semibold text-white shadow" : "rounded bg-blue-600 px-3 py-2 text-sm text-white" %>
      <div class="flex items-center gap-2">
        <%= button_to "失敗分を一括再dispatch", retry_failed_admin_generated_file_events_path(@filters.compact_blank), method: :post, class: bulk_retry_class %>
        <%= link_to "すべて", admin_generated_file_events_path, class: "rounded border px-3 py-2" %>
        <% GeneratedFileEvent.statuses.keys.each do |status| %>
          <%= link_to generated_file_event_status_label(status), admin_generated_file_events_path(status: status), class: "rounded border px-3 py-2" %>
        <% end %>
      </div>
      <p class="text-xs text-gray-500">一括再dispatchは古い失敗分から最大100件です。</p>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-3 md:grid-cols-4">
    <% GeneratedFileEvent.statuses.keys.each do |status| %>
      <%= link_to admin_generated_file_events_path(status: status), class: "rounded-lg border bg-white p-4" do %>
        <div class="text-xs font-semibold uppercase text-gray-500"><%= generated_file_event_status_label(status) %></div>
        <div class="mt-1 text-2xl font-bold"><%= @status_counts.fetch(status, 0) %></div>
      <% end %>
    <% end %>
  </div>

  <%= form_with url: admin_generated_file_events_path, method: :get, local: true, class: "rounded-lg border bg-white p-4" do |form| %>
    <div class="grid grid-cols-1 gap-3 md:grid-cols-4">
      <div>
        <%= form.label :status, "状態", class: "block text-sm font-semibold" %>
        <%= form.select :status, options_for_select([["すべて", ""]] + GeneratedFileEvent.statuses.keys.map { [generated_file_event_status_label(_1), _1] }, @filters[:status]), {}, class: "mt-1 w-full rounded border px-2 py-1" %>
      </div>
      <div>
        <%= form.label :operation, "操作種別", class: "block text-sm font-semibold" %>
        <%= form.select :operation, options_for_select([["すべて", ""]] + %w[create update delete].map { [generated_file_operation_label(_1), _1] }, @filters[:operation]), {}, class: "mt-1 w-full rounded border px-2 py-1" %>
      </div>
      <div>
        <%= form.label :event_source, "イベント発生元", class: "block text-sm font-semibold" %>
        <%= form.text_field :event_source, value: @filters[:event_source], class: "mt-1 w-full rounded border px-2 py-1" %>
      </div>
      <div>
        <%= form.label :path, "パスを含む", class: "block text-sm font-semibold" %>
        <%= form.text_field :path, value: @filters[:path], class: "mt-1 w-full rounded border px-2 py-1" %>
        <p class="mt-1 text-xs text-gray-500">Windowsの区切り文字 \ は / として検索します。</p>
      </div>
      <div>
        <%= form.label :scheduled_from, "実行予定日(開始)", class: "block text-sm font-semibold" %>
        <%= form.text_field :scheduled_from, value: @filters[:scheduled_from], placeholder: "YYYY-MM-DD", class: "mt-1 w-full rounded border px-2 py-1" %>
      </div>
      <div>
        <%= form.label :scheduled_to, "実行予定日(終了)", class: "block text-sm font-semibold" %>
        <%= form.text_field :scheduled_to, value: @filters[:scheduled_to], placeholder: "YYYY-MM-DD", class: "mt-1 w-full rounded border px-2 py-1" %>
      </div>
      <div class="flex items-end gap-2">
        <%= form.submit "絞り込み", class: "rounded bg-blue-600 px-3 py-2 text-sm text-white" %>
        <%= link_to "クリア", admin_generated_file_events_path, class: "rounded border px-3 py-2 text-sm" %>
      </div>
    </div>
  <% end %>

  <%= render "admin/shared/pagination",
    total_count: @total_count,
    page: @page,
    total_pages: @total_pages,
    path: ->(target_page) { admin_generated_file_events_path(request.query_parameters.merge(page: target_page, per_page: @per_page)) } %>

  <div class="overflow-x-auto rounded-lg border bg-white">
    <table class="min-w-full divide-y divide-gray-200 text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-3 text-left font-semibold">イベントID</th>
          <th class="px-4 py-3 text-left font-semibold">状態</th>
          <th class="px-4 py-3 text-left font-semibold">パス</th>
          <th class="px-4 py-3 text-left font-semibold">操作種別</th>
          <th class="px-4 py-3 text-left font-semibold">発生元</th>
          <th class="px-4 py-3 text-left font-semibold">エラー</th>
          <th class="px-4 py-3 text-left font-semibold">回数</th>
          <th class="px-4 py-3 text-left font-semibold">実行予定</th>
          <th class="px-4 py-3 text-left font-semibold">処理完了</th>
          <th class="px-4 py-3 text-left font-semibold">操作</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% if @generated_file_events.any? %>
          <% @generated_file_events.each do |event| %>
            <tr>
              <td class="px-4 py-3 font-mono">
                <%= link_to event.public_id, admin_generated_file_event_path(event.public_id, detail_path_params), class: "text-blue-600 underline" %>
              </td>
              <td class="px-4 py-3"><%= generated_file_event_status_label(event.status) %></td>
              <td class="px-4 py-3 font-mono"><%= event.path %></td>
              <td class="px-4 py-3"><%= generated_file_operation_label(event.operation) %></td>
              <td class="px-4 py-3"><%= event.event_source.presence || "-" %></td>
              <td class="max-w-xs truncate px-4 py-3 text-gray-700" title="<%= event.error_message %>"><%= event.error_message.presence || "-" %></td>
              <td class="px-4 py-3"><%= event.occurrences_count %></td>
              <td class="px-4 py-3"><%= l(event.scheduled_at, format: :long) if event.scheduled_at %></td>
              <td class="px-4 py-3"><%= l(event.processed_at, format: :long) if event.processed_at %></td>
              <td class="px-4 py-3">
                <div class="flex gap-2">
                  <%= link_to "詳細", admin_generated_file_event_path(event.public_id, detail_path_params), class: "rounded border px-2 py-1 text-xs" %>
                  <%= button_to "再dispatch", retry_dispatch_admin_generated_file_event_path(event.public_id), method: :post, class: "rounded bg-blue-600 px-2 py-1 text-xs text-white" %>
                </div>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="10" class="px-4 py-8 text-center text-gray-500">条件に一致する生成ファイルイベントはありません。</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
