<%
  detail_path_params = { return_to: request.fullpath }
  status_filter_params = request.query_parameters.except(:page, :per_page).compact_blank
  current_status_filter = @filters[:status].presence
  status_quick_link_base_class = "rounded border px-3 py-2"
  status_quick_link_current_class = "#{status_quick_link_base_class} border-blue-600 bg-blue-50 font-semibold text-blue-700 ring-2 ring-blue-100"
  status_quick_link_default_class = "#{status_quick_link_base_class} text-gray-700 hover:bg-gray-50"
  has_active_filters = @filters.compact_blank.any?
  bulk_retry_target_count = @bulk_retry_target_count.to_i
  bulk_retry_available = bulk_retry_target_count.positive?
  bulk_retry_confirm_message = "現在の条件に一致する失敗イベント #{bulk_retry_target_count} 件のうち、古い順に最大100件を一括再投入します。現在の条件を確認してから実行してください。実行しますか？"
  bulk_retry_form_options = bulk_retry_available ? { data: { turbo_confirm: bulk_retry_confirm_message } } : {}
  table_key = :admin_generated_file_events
  table_columns = generated_file_event_table_columns
  table_settings = rails_table_preference_settings(table_key: table_key)
  query_max_length = Admin::GeneratedFileEventsController::QUERY_MAX_LENGTH
%>

<div class="space-y-6">
  <div class="flex items-start justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold">生成ファイルイベント</h1>
      <p class="text-sm text-gray-600">debounce / coalesce 用に蓄積されたファイル変更イベントです。</p>
    </div>
    <div class="flex flex-col gap-3 text-sm md:flex-row md:items-start md:justify-end">
      <% bulk_retry_class = if !bulk_retry_available
           "rounded bg-gray-300 px-3 py-2 text-sm text-gray-600"
         elsif @filters[:status] == "failed"
           "rounded bg-red-600 px-3 py-2 text-sm font-semibold text-white shadow"
         else
           "rounded bg-blue-600 px-3 py-2 text-sm text-white"
         end %>
      <div class="rounded border border-red-100 bg-red-50 p-3 text-left">
        <p class="text-xs font-semibold uppercase text-red-700">実行操作</p>
        <div class="mt-2 flex flex-wrap items-center gap-2">
          <%= button_to "失敗分を一括再投入", retry_failed_admin_generated_file_events_path(@filters.compact_blank), method: :post, class: bulk_retry_class, disabled: !bulk_retry_available, form: bulk_retry_form_options %>
        </div>
        <p class="mt-2 text-xs text-gray-600">再投入は表示フィルタではなく、現在の条件に一致する失敗イベントを再投入する操作です。</p>
        <p class="mt-1 text-xs text-gray-500">現在の条件で再投入対象: <%= @bulk_retry_target_count %> 件</p>
        <p class="text-xs text-gray-500">一括再投入は古い失敗分から最大100件です。</p>
        <% unless bulk_retry_available %>
          <p class="text-xs text-gray-500">対象がないため一括再投入できません。</p>
        <% end %>
      </div>
      <div class="rounded border bg-white p-3 text-left">
        <p class="text-xs font-semibold uppercase text-gray-600">表示フィルタ</p>
        <div class="mt-2 flex flex-wrap items-center gap-2">
          <% all_status_current = current_status_filter.blank? %>
          <%= link_to "すべて", admin_generated_file_events_path(status_filter_params.except("status")), class: all_status_current ? status_quick_link_current_class : status_quick_link_default_class, aria: (all_status_current ? { current: "page" } : {}) %>
          <% GeneratedFileEvent.statuses.keys.each do |status| %>
            <% status_current = current_status_filter == status %>
            <%= link_to generated_file_event_status_label(status), admin_generated_file_events_path(status_filter_params.merge("status" => status)), class: status_current ? status_quick_link_current_class : status_quick_link_default_class, aria: (status_current ? { current: "page" } : {}) %>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-3 md:grid-cols-4">
    <% GeneratedFileEvent.statuses.keys.each do |status| %>
      <%= link_to admin_generated_file_events_path(status_filter_params.merge("status" => status)), class: "rounded-lg border bg-white p-4" do %>
        <div class="text-xs font-semibold uppercase text-gray-500"><%= generated_file_event_status_label(status) %></div>
        <div class="mt-1 text-2xl font-bold"><%= @status_counts.fetch(status, 0) %></div>
      <% end %>
    <% end %>
  </div>

  <% if @filter_warnings.present? %>
    <div class="rounded border border-amber-300 bg-amber-50 p-3 text-sm text-amber-900">
      <p class="font-semibold">日時フィルタを確認してください。</p>
      <ul class="mt-1 list-disc pl-5">
        <% @filter_warnings.each do |warning| %>
          <li><%= warning %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with url: admin_generated_file_events_path, method: :get, local: true, class: "rounded-lg border bg-white p-4" do |form| %>
    <div class="grid grid-cols-1 gap-3 md:grid-cols-4">
      <div>
        <%= form.label :q, "イベントID / パス / エラー", class: "block text-sm font-semibold" %>
        <%= form.search_field :q, value: @filters[:q], maxlength: query_max_length, class: "mt-1 w-full rounded border px-2 py-1" %>
        <p class="mt-1 text-xs text-gray-500">最大100文字。イベントID、パス、エラーの短い断片で探します。パス内の \\ は / として検索します。</p>
      </div>
      <div>
        <%= form.label :status, "状態", class: "block text-sm font-semibold" %>
        <%= form.select :status, options_for_select([["すべて", ""]] + GeneratedFileEvent.statuses.keys.map { [generated_file_event_status_label(_1), _1] }, @filters[:status]), {}, class: "mt-1 w-full rounded border px-2 py-1" %>
      </div>
      <div>
        <%= form.label :operation, "操作種別", class: "block text-sm font-semibold" %>
        <%= form.select :operation, options_for_select([["すべて", ""]] + %w[create update delete].map { [generated_file_operation_label(_1), _1] }, @filters[:operation]), {}, class: "mt-1 w-full rounded border px-2 py-1" %>
      </div>
      <div>
        <%= form.label :event_source, "イベント発生元", class: "block text-sm font-semibold" %>
        <%= form.text_field :event_source, value: @filters[:event_source], class: "mt-1 w-full rounded border px-2 py-1" %>
        <p class="mt-1 text-xs text-gray-500">保存値と完全一致する発生元だけに絞り込みます。短い断片で探す場合は「イベントID / パス / エラー」を使ってください。</p>
      </div>
      <div>
        <%= form.label :path, "パスを含む", class: "block text-sm font-semibold" %>
        <%= form.text_field :path, value: @filters[:path], maxlength: query_max_length, class: "mt-1 w-full rounded border px-2 py-1" %>
        <p class="mt-1 text-xs text-gray-500">最大100文字。Windowsの区切り文字 \\ は / として検索します。</p>
      </div>
      <div>
        <%= form.label :scheduled_from, "実行予定日(開始)", class: "block text-sm font-semibold" %>
        <%= form.text_field :scheduled_from, value: @filters[:scheduled_from], placeholder: "YYYY-MM-DD", class: "mt-1 w-full rounded border px-2 py-1" %>
        <p class="mt-1 text-xs text-gray-500">日付だけ指定すると、その日の00:00以降を含みます。</p>
      </div>
      <div>
        <%= form.label :scheduled_to, "実行予定日(終了)", class: "block text-sm font-semibold" %>
        <%= form.text_field :scheduled_to, value: @filters[:scheduled_to], placeholder: "YYYY-MM-DD", class: "mt-1 w-full rounded border px-2 py-1" %>
        <p class="mt-1 text-xs text-gray-500">日付だけ指定すると、その日の23:59までを含みます。</p>
      </div>
      <div class="flex items-end gap-2">
        <%= form.submit "絞り込み", class: "rounded bg-blue-600 px-3 py-2 text-sm text-white" %>
        <% if has_active_filters %>
          <%= link_to "絞り込みを解除", admin_generated_file_events_path, class: "rounded border px-3 py-2 text-sm" %>
        <% end %>
      </div>
    </div>
  <% end %>

  <%= render "admin/shared/pagination",
    total_count: @total_count,
    page: @page,
    total_pages: @total_pages,
    path: ->(target_page) { admin_generated_file_events_path(request.query_parameters.merge(page: target_page, per_page: @per_page)) } %>

  <% if @generated_file_events.any? %>
    <div class="rounded-lg border bg-white p-4">
      <%= table_preferences_editor(table_key: table_key, settings: table_settings, columns: table_columns, title: "生成ファイルイベント一覧の表示設定") %>
    </div>
  <% end %>

  <div class="overflow-x-auto rounded-lg border bg-white">
    <%= table_preferences_table_tag(table_key: table_key, settings: table_settings, columns: table_columns) do %>
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-3 text-left font-semibold" data-rails-table-preferences-column-key="public_id">イベントID</th>
          <th class="px-4 py-3 text-left font-semibold" data-rails-table-preferences-column-key="status">状態</th>
          <th class="px-4 py-3 text-left font-semibold" data-rails-table-preferences-column-key="path">パス</th>
          <th class="px-4 py-3 text-left font-semibold" data-rails-table-preferences-column-key="operation">操作種別</th>
          <th class="px-4 py-3 text-left font-semibold" data-rails-table-preferences-column-key="event_source">発生元</th>
          <th class="px-4 py-3 text-left font-semibold" data-rails-table-preferences-column-key="error_message">エラー</th>
          <th class="px-4 py-3 text-left font-semibold" data-rails-table-preferences-column-key="occurrences_count">回数</th>
          <th class="px-4 py-3 text-left font-semibold" data-rails-table-preferences-column-key="scheduled_at">実行予定</th>
          <th class="px-4 py-3 text-left font-semibold" data-rails-table-preferences-column-key="processed_at">処理完了</th>
          <th class="px-4 py-3 text-left font-semibold" data-rails-table-preferences-column-key="actions">操作</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% if @generated_file_events.any? %>
          <% @generated_file_events.each do |event| %>
            <tr>
              <td class="px-4 py-3 font-mono" data-rails-table-preferences-column-key="public_id">
                <%= link_to event.public_id, admin_generated_file_event_path(event.public_id, detail_path_params), class: "text-blue-600 underline" %>
              </td>
              <td class="px-4 py-3" data-rails-table-preferences-column-key="status"><%= generated_file_event_status_label(event.status) %></td>
              <td class="px-4 py-3 font-mono" data-rails-table-preferences-column-key="path"><%= event.path %></td>
              <td class="px-4 py-3" data-rails-table-preferences-column-key="operation"><%= generated_file_operation_label(event.operation) %></td>
              <td class="px-4 py-3" data-rails-table-preferences-column-key="event_source"><%= generated_file_source_label(event.event_source) %></td>
              <td class="max-w-xs truncate px-4 py-3 text-gray-700" data-rails-table-preferences-column-key="error_message"><%= generated_file_event_error_preview(event.error_message) %></td>
              <td class="px-4 py-3" data-rails-table-preferences-column-key="occurrences_count"><%= event.occurrences_count %></td>
              <td class="px-4 py-3" data-rails-table-preferences-column-key="scheduled_at"><%= l(event.scheduled_at, format: :long) if event.scheduled_at %></td>
              <td class="px-4 py-3" data-rails-table-preferences-column-key="processed_at"><%= l(event.processed_at, format: :long) if event.processed_at %></td>
              <td class="px-4 py-3" data-rails-table-preferences-column-key="actions">
                <div class="flex gap-2">
                  <%= link_to "詳細", admin_generated_file_event_path(event.public_id, detail_path_params), class: "rounded border px-2 py-1 text-xs" %>
                  <%= button_to "このイベントを再投入", retry_dispatch_admin_generated_file_event_path(event.public_id), method: :post, class: "rounded bg-blue-600 px-2 py-1 text-xs text-white", title: "#{event.public_id} を再投入キューに投入", aria: {label: "#{event.public_id} を再投入キューに投入"} %>
                </div>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="<%= table_columns.size %>" class="px-4 py-8 text-center text-gray-500">
              <% if has_active_filters %>
                <div class="generated-file-event-filter-empty-state space-y-2">
                  <p>検索条件に一致する生成ファイルイベントはありません。</p>
                  <p class="text-sm">これは表示フィルタの結果です。一括再投入対象の有無とは別に、条件を見直すか、すべての生成ファイルイベントを表示してください。</p>
                  <p class="actions mt-3"><%= link_to "すべての生成ファイルイベントを見る", admin_generated_file_events_path, class: "rounded border px-3 py-2 text-sm" %></p>
                </div>
              <% else %>
                <div class="generated-file-event-initial-empty-state space-y-2">
                  <p>生成ファイルイベントはまだありません。</p>
                  <p class="text-sm">生成対象のファイル変更イベントが蓄積されると、ここに debounce / coalesce 後のイベントが表示されます。イベント 0 件は、生成処理が成功していることやエラーがないことを示すものではありません。</p>
                  <p class="actions mt-3"><%= link_to "生成ファイル実行履歴を確認する", admin_generated_file_runs_path, class: "rounded border px-3 py-2 text-sm" %></p>
                </div>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    <% end %>
  </div>
</div>