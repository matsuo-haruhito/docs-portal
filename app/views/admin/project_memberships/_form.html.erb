<%= render "shared/error_messages", record: project_membership %>

<%= form_with model: [:admin, project_membership] do |form| %>
  <div class="form-grid">
    <%= form.rfk_select :project_id,
      collection: @projects.map { [project_membership_project_option_label(_1), _1.id] },
      wrapper: true,
      label: "案件",
      placeholder: "案件を選択" %>
    <%= form.rfk_select :user_id,
      collection: @users.map { [project_membership_user_option_label(_1), _1.id] },
      wrapper: true,
      label: "ユーザー",
      placeholder: "ユーザーを選択" %>
    <label>
      権限
      <%= form.select :role, enum_options_for("project_memberships.role", ProjectMembership.roles.keys) %>
    </label>
  </div>
  <p class="actions" style="margin-top:16px;">
    <%= form.submit "保存", class: "button" %>
    <% if project_membership.persisted? %>
      <%= link_to "一覧へ戻る", admin_project_memberships_path, class: "button secondary" %>
    <% end %>
  </p>
<% end %>
