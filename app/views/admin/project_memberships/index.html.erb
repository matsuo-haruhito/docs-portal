<% page_title "案件所属" %>
<% table_key = :admin_project_memberships %>
<% table_columns = project_membership_table_columns %>
<% table_settings = rails_table_preference_settings(table_key: table_key) %>

<h1>案件所属</h1>
<%= render "admin/nav" %>

<div class="card">
  <h2>新規登録</h2>
  <%= render "form", project_membership: @project_membership %>
</div>

<% if @project_memberships_total_count.positive? %>
  <div class="card">
    <%= table_preferences_editor(table_key: table_key, settings: table_settings, columns: table_columns, title: "案件所属一覧の表示設定") %>
    <p class="muted">表示設定は列の表示切り替え用です。ページ移動と1ページあたりの件数は下のページ情報で確認できます。</p>
  </div>

  <p class="muted">
    <% start_index = ((@project_memberships_page - 1) * @project_memberships_per_page) + 1 %>
    <% end_index = [start_index + @project_memberships.size - 1, @project_memberships_total_count].min %>
    表示中: <%= start_index %>-<%= end_index %>件 / 全<%= @project_memberships_total_count %>件（1ページ<%= @project_memberships_per_page %>件）
  </p>

  <p class="actions">
    <% if @project_memberships_page > 1 %>
      <%= link_to "前へ", admin_project_memberships_path(page: @project_memberships_page - 1, per_page: @project_memberships_per_page), class: "button secondary" %>
    <% else %>
      <span class="button secondary" aria-disabled="true">前へ（先頭）</span>
    <% end %>
    <span class="muted">Page <%= @project_memberships_page %> / <%= @project_memberships_total_pages %></span>
    <% if @project_memberships_total_pages == 1 %>
      <span class="muted">1ページのみ</span>
    <% elsif @project_memberships_page == 1 %>
      <span class="muted">先頭ページ</span>
    <% elsif @project_memberships_page == @project_memberships_total_pages %>
      <span class="muted">最終ページ</span>
    <% end %>
    <% if @project_memberships_page < @project_memberships_total_pages %>
      <%= link_to "次へ", admin_project_memberships_path(page: @project_memberships_page + 1, per_page: @project_memberships_per_page), class: "button secondary" %>
    <% else %>
      <span class="button secondary" aria-disabled="true">次へ（最終）</span>
    <% end %>
  </p>

  <%= table_preferences_table_tag(table_key: table_key, settings: table_settings, columns: table_columns) do %>
    <thead>
      <tr>
        <th data-rails-table-preferences-column-key="project">案件</th>
        <th data-rails-table-preferences-column-key="user">ユーザー</th>
        <th data-rails-table-preferences-column-key="role">権限</th>
        <th data-rails-table-preferences-column-key="actions">操作</th>
      </tr>
    </thead>
    <tbody>
      <% @project_memberships.each do |membership| %>
        <tr>
          <td data-rails-table-preferences-column-key="project">
            <%= membership.project.name %>
            <% if membership.project.code.present? %>
              <br>
              <code><%= membership.project.code %></code>
            <% end %>
          </td>
          <td data-rails-table-preferences-column-key="user"><%= project_membership_user_option_label(membership.user) %></td>
          <td data-rails-table-preferences-column-key="role"><span class="badge"><%= project_membership_role_label(membership) %></span></td>
          <td class="actions" data-rails-table-preferences-column-key="actions">
            <%= edit_link_to "編集", edit_admin_project_membership_path(membership) %>
            <%= delete_link_to "削除", admin_project_membership_path(membership), confirm: "案件所属を削除しますか？このユーザーは案件へアクセスできなくなります。" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  <% end %>
<% else %>
  <div class="card">
    <p class="muted">まだ案件所属はありません。</p>
    <p class="muted">上の「新規登録」で案件、ユーザー、権限を選んで保存すると、ここに一覧が表示されます。</p>
    <p class="muted">この画面では、案件アクセスの入口になる所属と権限を確認できます。</p>
  </div>
<% end %>