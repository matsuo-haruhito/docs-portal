<%= render "shared/error_messages", record: document %>

<%= form_with model: [:admin, document] do |form| %>
  <div class="form-grid">
    <label>
      案件
      <%= form.collection_select :project_id, @projects, :id, :name %>
    </label>
    <label>
      タイトル
      <%= form.text_field :title %>
    </label>
    <label>
      スラッグ
      <%= form.text_field :slug %>
    </label>
    <label>
      カテゴリ
      <%= form.select :category, Document.categories.keys.map { |key| [key, key] } %>
    </label>
    <label>
      文書種別
      <%= form.select :document_kind, Document.document_kinds.keys.map { |key| [key, key] } %>
    </label>
    <label>
      公開範囲
      <%= form.select :visibility_policy, Document.visibility_policies.keys.map { |key| [key, key] } %>
    </label>
  </div>
  <p class="actions" style="margin-top:16px;">
    <%= form.submit "保存", class: "button" %>
    <% if document.persisted? %>
      <%= link_to "一覧へ戻る", admin_documents_path, class: "button secondary" %>
    <% end %>
  </p>
<% end %>
