<h1>管理画面</h1>
<p class="muted">内部ユーザーのみが各種マスタを管理できます。</p>

<%= render "admin/nav" %>

<div class="form-grid">
  <div class="card">
    <h2>基本マスタ</h2>
    <ul>
      <% if company_master_admin? %>
        <li><%= link_to "会社マスタ", admin_companies_path %></li>
      <% end %>
      <li><%= link_to "ユーザーマスタ", admin_users_path %></li>
      <li><%= link_to "案件マスタ", admin_projects_path %></li>
    </ul>
  </div>
  <div class="card">
    <h2>関連設定</h2>
    <ul>
      <li><%= link_to "案件所属", admin_project_memberships_path %></li>
      <li><%= link_to "文書マスタ", admin_documents_path %></li>
      <li><%= link_to "文書公開権限", admin_document_permissions_path %></li>
    </ul>
  </div>
</div>
