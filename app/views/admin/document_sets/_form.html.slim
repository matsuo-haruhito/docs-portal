= render "shared/error_messages", record: document_set

- selected_items = document_set.document_set_items.index_by(&:document_id)
- form_url = document_set.persisted? ? admin_document_set_path(document_set) : admin_document_sets_path(@filters.presence || {})

= form_with model: [:admin, document_set], url: form_url do |form|
  .form-grid
    = form.rfk_select :project_id,
      collection: @projects,
      collection_value_method: :id,
      collection_label_method: :name,
      wrapper: true,
      label: "案件",
      allow_clear: true,
      placeholder: "案件を選択"
    = form.rfk_text_field :name, wrapper: true, label: "名称"
    = form.rfk_select :set_type,
      collection: enum_options_for("document_sets.set_type", DocumentSet.set_types.keys),
      wrapper: true,
      label: "種別"
    = form.rfk_select :visibility_policy,
      collection: enum_options_for("document_sets.visibility_policy", DocumentSet.visibility_policies.keys),
      wrapper: true,
      label: "公開範囲"
    = form.rfk_number_field :sort_order, min: 0, wrapper: true, label: "表示順"
    = form.rfk_text_area :description,
      wrapper: true,
      label: "説明",
      wrapper_html: { style: "grid-column: 1 / -1;" }

  - if @project_documents.any?
    h2 対象文書
    p.muted チェックした文書だけセットに含めます。版固定しない場合は最新版を使います。
    table
      thead
        tr
          th 対象
          th 文書名
          th 固定版
          th 並び順
          th メモ
      tbody
        - @project_documents.each_with_index do |document, index|
          - item = selected_items[document.id]
          tr
            td
              = hidden_field_tag "document_set_items[#{index}][document_id]", document.id
              = check_box_tag "document_set_items[#{index}][selected]", "1", item.present?
            td
              strong = link_to document.title, project_document_path(document.project, document.slug)
              br
              span.muted = "URL識別子: #{document.slug}"
            td
              - version_options = [["最新版を使う", ""]] + document.document_versions.sort_by(&:created_at).reverse.map { |version| ["#{document_version_label(version)} (#{document_version_status_label(version)})", version.id] }
              = select_tag("document_set_items[#{index}][document_version_id]", options_for_select(version_options, item&.document_version_id), document_set_version_select_html_options)
            td
              = number_field_tag "document_set_items[#{index}][sort_order]", item&.sort_order || index, min: 0
            td
              = text_field_tag "document_set_items[#{index}][note]", item&.note
  - elsif document_set.project_id.present?
    h2 対象文書
    p.muted まだ対象文書がありません。
    p.muted この案件に文書を取り込むと、ここで対象文書を選べます。
    p.muted
      | まず
      = link_to "Git連携", admin_git_import_sources_path
      | 、
      = link_to "Git同期履歴", admin_git_import_runs_path
      | 、
      = link_to "ZIPインポート", new_admin_zip_import_path
      | を確認してから戻ってください。
  - else
    p.muted 案件を選ぶと対象文書を設定できます。

  p.actions style="margin-top:16px;"
    = form.submit "保存", class: "button"
    - if document_set.persisted?
      = link_to "一覧へ戻る", admin_document_sets_path, class: "button secondary"
