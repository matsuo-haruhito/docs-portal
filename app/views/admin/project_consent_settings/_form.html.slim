= render "shared/error_messages", record: project_consent_setting

= form_with model: [:admin, project_consent_setting] do |form|
  .form-grid
    = form.rfk_combobox :project_id,
      collection: [],
      selected: project_consent_setting_project_selected_option(project_consent_setting.project || @selected_project),
      url: project_search_admin_project_consent_settings_path(format: :json),
      selected_url: selected_project_admin_project_consent_settings_path(format: :json),
      value_field: "value",
      label_field: "text",
      search_field: "text",
      min_length: 1,
      max_options: Admin::ProjectConsentSettingsController::PROJECT_SEARCH_LIMIT,
      wrapper: true,
      label: "案件",
      placeholder: "案件コード・案件名で検索"
    = form.rfk_combobox :consent_term_id,
      collection: [],
      selected: project_consent_term_selected_option(project_consent_setting.consent_term || @selected_consent_term),
      url: consent_term_search_admin_project_consent_settings_path(format: :json),
      selected_url: selected_consent_term_admin_project_consent_settings_path(format: :json),
      value_field: "value",
      label_field: "text",
      search_field: "text",
      min_length: 1,
      max_options: Admin::ProjectConsentSettingsController::CONSENT_TERM_SEARCH_LIMIT,
      wrapper: true,
      label: "同意文面",
      placeholder: "同意文面名・版で検索"
    label
      | 必須タイミング
      = form.select :required_on, project_consent_setting_required_on_options
    label
      | 状態
      = form.select :enabled, [["有効", true], ["無効", false]]
  p.muted first_access は閲覧前、download は ZIP・添付ファイルのダウンロード前に確認します。shared_link 系は共有リンク実装時の拡張用です。
  p.actions
    = form.submit "保存", class: "button"
    - if project_consent_setting.persisted?
      = link_to "一覧へ戻る", admin_project_consent_settings_path, class: "button secondary"
