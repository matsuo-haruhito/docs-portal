COMPOSE_FILE=docker-compose.yml

RAILS_SERVE_STATIC_FILES=true
RAILS_FORCE_SSL=
RAILS_LOG_TO_STDOUT=
RAILS_LOG_SHIFT_AGE=5
RAILS_COLORIZE_LOGGING=true
RAILS_MAX_THREADS=5
RAILS_MASTER_KEY=replace_me
SECRET_KEY_BASE=secret

APP_UID=1000
APP_GID=1000

DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_NAME=docs_portal
DATABASE_PASSWORD=docs_portal

ACTIVE_STORAGE_SERVICE=local
DOC_IMPORT_TOKEN=local-dev-import-token
DOCUSAURUS_RENDERER_ENDPOINT=http://docusaurus:3000
KROKI_ENDPOINT=http://kroki:8000

# Generate with: bin/rails db:encryption:init
# Keep production values secret and provide them via deploy-time environment variables.
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=replace_me
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=replace_me
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=replace_me

GOOGLE_DRIVE_OAUTH_CLIENT_ID=replace_me
GOOGLE_DRIVE_OAUTH_CLIENT_SECRET=replace_me

GOOGLE_DRIVE_PREVIEW_FOLDER_ID=replace_me
GOOGLE_DRIVE_PREVIEW_UPLOAD_TTL_HOURS=168

PUBLISH_WEB_SERVER_PORT=3000
PUBLISH_DATABASE_PORT=5432
PUBLISH_DOCUSAURUS_RENDERER_PORT=3001
